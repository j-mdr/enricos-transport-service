# Site URL
PUBLIC_SITE_URL=https://enricostransportservice.nl

# Cloudflare Turnstile
# Maak een site aan op https://dash.cloudflare.com/turnstile
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Google Analytics
# Vind je Measurement ID in Google Analytics > Beheer > Gegevensstroom
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# StaticForms
# Maak een access key aan op https://www.staticforms.xyz/
# Configureer de ontvanger-email in je StaticForms dashboard (gekoppeld aan de access key)
STATICFORMS_ACCESS_KEY=your_staticforms_access_key_here