{
  "name": "enricos-transport-service",
  // Set this to today's date
  "compatibility_date": "2026-03-18",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "ets.j-mdr.com",
      "custom_domain": true
    }
  ],
}
