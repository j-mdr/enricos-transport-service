---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCardFull from "@components/PostCard/PostCardFull.astro";
import CategoryCloud from "@components/CategoryCloud/CategoryCloud.astro";
import { getAllCategories, getBlogPostsByCategory } from "@lib/groq/blogPost";
import type { GetAllCategoriesQueryResult } from "../../../../sanity.types";

const categoryParam = Astro.params.category as string;
const categories = (await getAllCategories("en")) as GetAllCategoriesQueryResult;
const cat = categories.find((c) => {
  const urlSegment = c.urlPath
    ? c.urlPath.replace(/^\/en\/categories\//, "")
    : (c.slug ?? "").replace(/^categories\//, "");
  return urlSegment === categoryParam;
});
if (!cat) return Astro.rewrite("/en/404");

const posts = await getBlogPostsByCategory(cat.slug ?? "", "en");
---

<BaseLayout
  type="general"
  title={cat.title ?? ""}
  description={cat.description ?? ""}
  alternatePaths={cat.alternatePaths}
>
  <section class="site-container pt-36 md:pt-44">
    <h1 class="h1 text-center">
      {cat.title}
    </h1>
    <div class="mt-6 flex justify-center">
      <CategoryCloud />
    </div>

    <div class="mt-20 grid gap-4 gap-y-12 md:mt-28">
      {posts.map((post) => <PostCardFull post={post} showDescription={true} />)}
    </div>
  </section>
</BaseLayout>
