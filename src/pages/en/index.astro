---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getPageBySlug } from "@lib/groq/page";

const page = await getPageBySlug("home-en", "en");
if (!page) return Astro.redirect("/en/404");

const { title, description, layout, image, seo } = page;
const alternatePaths = { nl: "/", en: "/en/" };
---

{
  layout !== "narrow" && (
    <BaseLayout
      title={seo?.title ?? title}
      description={seo?.description ?? description}
      type={"general"}
      alternatePaths={alternatePaths}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </BaseLayout>
  )
}

{
  layout === "narrow" && (
    <ServiceLayoutCenter
      title={title}
      description={description}
      image={image}
      alternatePaths={alternatePaths}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </ServiceLayoutCenter>
  )
}
