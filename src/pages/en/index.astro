---
import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";

const page = await getEntry("otherPages", "en/home");
if (!page) return Astro.redirect("/en/404");

const { title, description, template, image } = page.data;
---

{
  template === "BaseLayout" && (
    <BaseLayout title={title} description={description}>
      <BlockRenderer blocks={page.data.blocks ?? []} />
    </BaseLayout>
  )
}

{
  template === "ServiceLayoutCenter" && (
    <ServiceLayoutCenter title={title} description={description} image={image}>
      <BlockRenderer blocks={page.data.blocks ?? []} />
    </ServiceLayoutCenter>
  )
}
