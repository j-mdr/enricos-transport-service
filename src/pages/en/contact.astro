---
// main layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import ContactFormSection from "@components/Contact/ContactFormSection.astro";

// utils
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getTranslatedData } from "@/utils/translationUtils";
import ContactInformationBlock from "@components/Contact/ContactInformationBlock.astro";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title="Contact Me" description="Get in touch! Contact information for Blogsmith.">
  <div class="site-container mx-auto pt-36 md:pt-44">
    <h1 class="h1 text-center">Contact Us</h1>
    <p class="description mx-auto mt-6 max-w-2xl text-center">
      When you fill out the form below, we will contact you to set up a time and take a look at your
      painting project. We look forward to meeting you!
    </p>
    <div class="mt-20 grid gap-8 lg:grid-cols-3">
      <!-- Contact info -->
      <div class="hidden flex-col lg:flex">
        <!-- gap to align with h2 of contact form -->
        <div class="h2 opacity-0">-</div>
        <ContactInformationBlock />
      </div>

      <!-- contact form -->
      <div class="lg:col-span-2">
        <ContactFormSection />
      </div>
    </div>
  </div>
</BaseLayout>
