---
import { type CollectionEntry, getCollection, render } from "astro:content";

// layouts
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";

// components
import ExternalLink from "@components/MarkdownComponents/ExternalLink.astro";
import FaqAccordionsSection from "@components/Faq/FaqAccordionsSection.astro";

// utils
import { filterCollectionByLanguage } from "@/utils/localeUtils";

export async function getStaticPaths() {
  const gebieden = await getCollection("deliveryAreas", ({ data }) => {
    // filter out draft entries
    return data.draft !== true;
  });

  // get rid of pages from other languages and remove locale from slug
  const filteredGebieden = filterCollectionByLanguage(gebieden, "en");

  return filteredGebieden.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"deliveryAreas">;

const gebied = Astro.props as Props;
const { Content } = await render(gebied);
const { template } = gebied.data;
---

{
  template === "ServiceLayoutCenter" && (
    <ServiceLayoutCenter {...gebied.data}>
      <Content components={{ a: ExternalLink, FaqSection: FaqAccordionsSection }} />
    </ServiceLayoutCenter>
  )
}
