---
export const prerender = true;
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllDeliveryAreas } from "@lib/groq/deliveryArea";

export async function getStaticPaths() {
  const areas = await getAllDeliveryAreas("en");

  return areas.map((area: { slug: string }) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const { title, description, image, seo, content } = area;
---

<ServiceLayoutCenter title={seo?.title ?? title} description={seo?.description ?? description} image={image}>
  <BlockRenderer blocks={content ?? []} />
</ServiceLayoutCenter>