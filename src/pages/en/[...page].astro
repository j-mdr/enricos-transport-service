---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllPages } from "@lib/groq/page";
import type { GetAllPagesQueryResult } from "../../../sanity.types";

type Page = GetAllPagesQueryResult[number];

export async function getStaticPaths() {
  const pages = await getAllPages("en");

  return pages
    .filter((page: Page) => page.path !== "home-en")
    .map((page: Page) => ({
      params: { page: page.path },
      props: { page },
    }));
}

const { page } = Astro.props as { page: Page };
const { title = "", description = "", layout, image, seo, alternatePaths } = page;
---

{
  layout !== "narrow" && (
    <BaseLayout
      title={seo?.title ?? title}
      description={seo?.description ?? description}
      type={"general"}
      alternatePaths={alternatePaths}
      blocks={page.blocks ?? undefined}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </BaseLayout>
  )
}

{
  layout === "narrow" && (
    <ServiceLayoutCenter
      title={title}
      description={description}
      image={image}
      alternatePaths={alternatePaths}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </ServiceLayoutCenter>
  )
}
