---
import BaseLayout from "@layouts/BaseLayout.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllPages } from "@lib/groq/page";
import type { GetAllPagesQueryResult } from "../../../sanity.types";
import { buildOgImageUrl } from "@lib/sanityImage";

type Page = GetAllPagesQueryResult[number];

export async function getStaticPaths() {
  const pages = await getAllPages("en");

  return pages
    .filter((page: Page) => page.path !== "home-en")
    .map((page: Page) => ({
      params: { page: page.path },
      props: { page },
    }));
}

const { page } = Astro.props as { page: Page };
const { title = "", description = "", seo, alternatePaths } = page;
const heroBlock = page.blocksTop?.find((b: any) => b.image?.asset);
const ogImageUrl = buildOgImageUrl(heroBlock?.image as any);
---

<BaseLayout
  title={title ?? ""}
  description={description ?? ""}
  seo={seo}
  type={"general"}
  ogImageUrl={ogImageUrl}
  alternatePaths={alternatePaths}
  blocks={page.blocks ?? undefined}
>
  <BlockRenderer blocks={page.blocksTop ?? []} />
  <div class="mx-auto max-w-3xl">
    <BlockRenderer blocks={page.blocks ?? []} />
  </div>
  <BlockRenderer blocks={page.blocksBottom ?? []} />
</BaseLayout>
