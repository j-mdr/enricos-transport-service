---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllPages } from "@lib/groq/page";
import { buildAlternatePaths } from "@utils/sanityTranslationUtils";

export async function getStaticPaths() {
  const pages = await getAllPages("en");

  return pages
    .filter((page: { slug: string }) => page.slug !== "home-en")
    .map((page: { slug: string }) => ({
      params: { page: page.slug },
      props: { page },
    }));
}

const { page } = Astro.props;
const { title, description, layout, image, seo, nav, footer, translations } = page;
const alternatePaths = buildAlternatePaths(translations, "page");
---

{
  layout !== "narrow" && (
    <BaseLayout
      title={seo?.title ?? title}
      description={seo?.description ?? description}
      type={"general"}
      navData={nav}
      footerData={footer}
      alternatePaths={alternatePaths}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </BaseLayout>
  )
}

{
  layout === "narrow" && (
    <ServiceLayoutCenter
      title={title}
      description={description}
      image={image}
      navData={nav}
      footerData={footer}
      alternatePaths={alternatePaths}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </ServiceLayoutCenter>
  )
}
