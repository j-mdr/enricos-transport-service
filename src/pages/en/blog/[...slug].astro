---
export const prerender = true;
import BlogLayout from "@layouts/BlogLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllBlogPosts } from "@lib/groq/blogPost";
import { buildAlternatePaths } from "@utils/sanityTranslationUtils";

export async function getStaticPaths() {
  const posts = await getAllBlogPosts("en");

  return posts.map((post: { slug: string }) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const alternatePaths = buildAlternatePaths(post.translations, "blogPost");
---

<BlogLayout post={post} alternatePaths={alternatePaths}>
  <BlockRenderer blocks={post.content ?? []} />
</BlogLayout>
