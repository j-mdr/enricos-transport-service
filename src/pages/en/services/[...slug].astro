---
import ServiceLayout from "@layouts/ServiceLayoutCenter.astro";
import { getServiceBySlug } from "@lib/groq/service";

const slug = Astro.params.slug;
if (!slug) return Astro.rewrite("/en/404");
const item = await getServiceBySlug(slug, "en");
if (!item) return Astro.rewrite("/en/404");
---

<ServiceLayout item={item} />
