---
import { type CollectionEntry } from "astro:content";

// layout
import BlogLayout from "@layouts/BlogLayoutCenter.astro";

// components
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";

// utils
import { getAllPosts } from "@/utils/blogUtils";
import { defaultLocale } from "@config/siteSettings.json";

export async function getStaticPaths() {
  const posts = await getAllPosts(defaultLocale);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props as Props;
---

<BlogLayout post={post}>
  <BlockRenderer blocks={post.data.blocks ?? []} />
</BlogLayout>
