---
import BlogLayout from "@layouts/BlogLayoutCenter.astro";
import { getBlogPostBySlug } from "@lib/groq/blogPost";

const slug = Astro.params.slug;
if (!slug) return Astro.rewrite("/404");
const post = await getBlogPostBySlug(slug, "nl");
if (!post) return Astro.rewrite("/404");
---

<BlogLayout post={post} />
