---
export const prerender = true;
import BlogLayout from "@layouts/BlogLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllBlogPosts } from "@lib/groq/blogPost";
import type {
  GetAllBlogPostsQueryResult,
  GetBlogPostBySlugQueryResult,
} from "../../../sanity.types";

type Post = NonNullable<GetBlogPostBySlugQueryResult>;

export async function getStaticPaths() {
  const posts = (await getAllBlogPosts("nl")) as GetAllBlogPostsQueryResult;

  return posts.map((post) => ({
    params: {
      slug: post.urlPath
        ? post.urlPath.replace(/^\/blog\//, "")
        : (post.slug ?? "").replace(/^blog\//, ""),
    },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
---

<BlogLayout post={post}>
  <BlockRenderer blocks={(post.blocks ?? []) as any} />
</BlogLayout>
