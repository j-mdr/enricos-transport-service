---
export const prerender = true;
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllServices } from "@lib/groq/service";

export async function getStaticPaths() {
  const services = await getAllServices("nl");

  return services.map((service: { slug: string }) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { title, description, image, seo, content } = service;
---

<ServiceLayoutCenter title={seo?.title ?? title} description={seo?.description ?? description} image={image}>
  <BlockRenderer blocks={content ?? []} />
</ServiceLayoutCenter>