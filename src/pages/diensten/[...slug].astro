---
import { type CollectionEntry, getCollection, render } from "astro:content";

// layouts
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";

// components
import ExternalLink from "@components/MarkdownComponents/ExternalLink.astro";
import FaqAccordionsSection from "@components/Faq/FaqAccordionsSection.astro";
import FaqCardsSection from "@components/Faq/FaqCardsSection.astro";
import CtaBgImageSection from "@components/Cta/CtaBgImageSection.astro";
import CtaCardCenterSection from "@components/Cta/CtaCardCenterSection.astro";
import CtaCardCenter2Section from "@components/Cta/CtaCardCenter2Section.astro";
import CtaCardsSection from "@components/Cta/CtaCardsSection.astro";
import FeatureCardsSmallSection from "@components/Feature/FeatureCardsSmallSection.astro";
import FeatureLightboxMarqueeSection from "@components/Feature/FeatureLightboxMarqueeSection.astro";
import FeatureGalleryMarqueeSection from "@components/Feature/FeatureGalleryMarqueeSection.astro";
import FeatureSideImageSection from "@components/Feature/FeatureSideImageSection.astro";
import FeatureToggleImageSection from "@components/Feature/FeatureToggleImageSection.astro";
import ServicesIconSection from "@components/Services/ServicesIconSection.astro";
import ServicesSideImageSection from "@components/Services/ServicesSideImageSection.astro";
import TestimonialsColumnsSection from "@components/Testimonials/TestimonialsColumnsSection.astro";
import TestimonialsSwiperSection from "@components/Testimonials/TestimonialsSwiperSection.astro";

// utils
import { filterCollectionByLanguage } from "@/utils/localeUtils";
import { defaultLocale } from "@config/siteSettings.json";

export async function getStaticPaths() {
  const services = await getCollection("services", ({ data }) => {
    // filter out draft services
    return data.draft !== true;
  });

  // get rid of pages from other languages and remove locale from slug
  const filteredServices = filterCollectionByLanguage(services, defaultLocale);

  return filteredServices.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"services">;

const service = Astro.props as Props;
const { Content } = await render(service);
const { template } = service.data;
---

{
  template === "ServiceLayoutCenter" && (
    <ServiceLayoutCenter {...service.data}>
      <Content
        components={{
          a: ExternalLink,
          FaqSection: FaqAccordionsSection,
          FaqCardsSection: FaqCardsSection,
          CtaBgImageSection: CtaBgImageSection,
          CtaCardCenterSection: CtaCardCenterSection,
          CtaCardCenter2Section: CtaCardCenter2Section,
          CtaCardsSection: CtaCardsSection,
          FeatureCardsSmallSection: FeatureCardsSmallSection,
          FeatureLightboxMarqueeSection: FeatureLightboxMarqueeSection,
          FeatureGalleryMarqueeSection: FeatureGalleryMarqueeSection,
          FeatureSideImageSection: FeatureSideImageSection,
          FeatureToggleImageSection: FeatureToggleImageSection,
          ServicesIconSection: ServicesIconSection,
          ServicesSideImageSection: ServicesSideImageSection,
          TestimonialsColumnsSection: TestimonialsColumnsSection,
          TestimonialsSwiperSection: TestimonialsSwiperSection,
        }}
      />
    </ServiceLayoutCenter>
  )
}
