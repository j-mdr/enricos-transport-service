---
export const prerender = true;
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllDeliveryAreas } from "@lib/groq/deliveryArea";
import { buildAlternatePaths } from "@utils/sanityTranslationUtils";

export async function getStaticPaths() {
  const areas = await getAllDeliveryAreas("nl");

  return areas.map((area: { slug: string }) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const { title, description, image, seo, content, nav, footer, translations } = area;
const alternatePaths = buildAlternatePaths(translations, "deliveryArea");
---

<ServiceLayoutCenter
  title={seo?.title ?? title}
  description={seo?.description ?? description}
  image={image}
  navData={nav}
  footerData={footer}
  alternatePaths={alternatePaths}
>
  <BlockRenderer blocks={content ?? []} />
</ServiceLayoutCenter>
