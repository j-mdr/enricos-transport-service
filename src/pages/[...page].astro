---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getAllPages } from "@lib/groq/page";

export async function getStaticPaths() {
  const pages = await getAllPages("nl");

  return pages
    .filter((page: { slug: string }) => page.slug !== "home-nl")
    .map((page: { slug: string }) => ({
      params: { page: page.slug },
      props: { page },
    }));
}

const { page } = Astro.props;
const { title, description, layout, image, seo } = page;
---

{
  layout !== "narrow" && (
    <BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} type={"general"}>
      <BlockRenderer blocks={page.blocks ?? []} />
    </BaseLayout>
  )
}

{
  layout === "narrow" && (
    <ServiceLayoutCenter title={title} description={description} image={image}>
      <BlockRenderer blocks={page.blocks ?? []} />
    </ServiceLayoutCenter>
  )
}