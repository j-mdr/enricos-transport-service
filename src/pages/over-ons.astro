---
import { Icon } from "astro-icon/components";
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaCardCenterSection from "@components/Cta/CtaCardCenterSection.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import TeamMemberCardsSection from "@components/Team/TeamMemberCardsSection.astro";
import Intro from "@components/Content/Intro.astro";
---

<BaseLayout title="Contact Me" description="Get in touch! Contact information for Blogsmith.">
  <Intro
    title="Het begin{highlight} van ons verhaal"
    introText="Ontdek de gepassioneerde individuen die onze content creëren, ons platform ontwerpen en onze missie drijven om bloggers wereldwijd te empoweren."
  />
  <TeamMemberCardsSection />
  <CtaCardCenterSection />
</BaseLayout>
