---
import BaseLayout from "@layouts/BaseLayout.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getHomePageFromSettings } from "@lib/groq/settings";
import { buildOgImageUrl } from "@lib/sanityImage";

const page = await getHomePageFromSettings("nl");
if (!page) return Astro.rewrite("/404");

const { title, seo } = page;
const alternatePaths = { nl: "/", en: "/en/" };
const heroBlock = page.blocks?.find((b: any) => b.image?.asset);
const ogImageUrl = buildOgImageUrl(heroBlock?.image as any);
---

<BaseLayout
  title={seo?.title ?? title ?? ""}
  description={seo?.description ?? ""}
  type={"general"}
  ogImageUrl={ogImageUrl}
  alternatePaths={alternatePaths}
  blocks={page.blocks ?? undefined}
>
  <BlockRenderer blocks={page.blocks ?? []} />
</BaseLayout>
