---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceLayoutCenter from "@layouts/ServiceLayoutCenter.astro";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { getPageBySlug } from "@lib/groq/page";

const page = await getPageBySlug("home-nl", "nl");
if (!page) return Astro.redirect("/404");

const { title, description, layout, image, seo, nav, footer } = page;
---

{
  layout !== "narrow" && (
    <BaseLayout
      title={seo?.title ?? title}
      description={seo?.description ?? description}
      type={"general"}
      navData={nav}
      footerData={footer}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </BaseLayout>
  )
}

{
  layout === "narrow" && (
    <ServiceLayoutCenter
      title={title}
      description={description}
      image={image}
      navData={nav}
      footerData={footer}
    >
      <BlockRenderer blocks={page.blocks ?? []} />
    </ServiceLayoutCenter>
  )
}
