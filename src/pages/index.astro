---
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroSideImageSection from "@components/Hero/HeroSideImageSection.astro";
import FeatureCardsSmallSection from "@components/Feature/FeatureCardsSmallSection.astro";
import ServicesSideImageSection from "@components/Services/ServicesSideImageSection.astro";
import TestimonialsSwiperSection from "@components/Testimonials/TestimonialsSwiperSection.astro";
import FeatureGalleryMarqueeSection from "@components/Feature/FeatureGalleryMarqueeSection.astro";
import FeatureLightboxMarqueeSection from "@components/Feature/FeatureLightboxMarqueeSection.astro";
import CtaCardCenterSection from "@components/Cta/CtaCardCenterSection.astro";
import FaqAccordionsSection from "@components/Faq/FaqAccordionsSection.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getTranslatedData, getLocalizedRoute } from "@/utils/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

const featureDataList = [
  {
    icon: "tabler/paint",
    title: "Persoonlijk & direct contact",
    text: `Our team of experienced painters uses high-quality materials and techniques to 
      ensure a flawless finish that will last for years to come.`,
  },
  {
    icon: "tabler/heart",
    title: "Flexibel maatwerktransport",
    text: `We believe that everyone deserves a beautifully painted space, and our commitment 
      to affordability reflects our dedication to making that a reality for our valued clients. `,
  },
  {
    icon: "tabler/clock",
    title: "24/7 spoedservice mogelijk",
    text: `We understand that time is of the essence, and we work efficiently to complete your 
      project in a timely manner without compromising quality.`,
  },
  {
    icon: "tabler/list-check",
    title: "Betrouwbare levering",
    text: `We prioritize customer satisfaction and work closely with our clients to ensure that 
      their vision is brought to life.`,
  },
  {
    icon: "tabler/home-heart",
    title: "Kwaliteit",
    text: `We use high-quality materials and techniques to ensure that our paint jobs are 
      durable and long-lasting.`,
  },
  {
    icon: "tabler/wand",
    title: "Vooruitstrevend",
    text: `Our team of skilled painters has an eye for detail and a passion for creating 
      beautiful spaces. We create stunning results that leave our clients thrilled.`,
  },
];
---

<BaseLayout title={siteData.title} description={siteData.description}>
  <HeroSideImageSection />
  <ServicesSideImageSection />
  <FeatureCardsSmallSection title="Onze kernwaarden{icon}" featureDataList={featureDataList} />
  <!--<TestimonialsSwiperSection />-->
  <!--<FeatureLightboxMarqueeSection />-->
  <!--<CtaCardCenterSection />-->
  <FaqAccordionsSection />
</BaseLayout>
