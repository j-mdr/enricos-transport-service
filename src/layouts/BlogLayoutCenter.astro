---
import BaseLayout from "./BaseLayout.astro";
import Button from "@components/Button/Button.astro";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import { formatDate } from "@/utils/textUtils";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import type { GetBlogPostBySlugQueryResult } from "../../sanity.types.ts";
import { getLocaleDefinition } from "@config/localeConfig.ts";
import BlockRenderer from "@components/BlockRenderer/BlockRenderer.astro";
import { buildOgImageUrl } from "@lib/sanityImage";

type Post = NonNullable<GetBlogPostBySlugQueryResult>;
interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, seo, authors, categories, pubDate, heroImage, alternatePaths, blocks } =
  post;

const currLocale = getLocaleFromUrl(Astro.url);
const localeDefinition = getLocaleDefinition(currLocale);

const backToAllPosts = currLocale === "en" ? "Back to all posts" : "Terug naar alle posts";

const ogImageUrl = buildOgImageUrl(heroImage);

const authorsList = (authors ?? []).map((a) => ({ name: a.name ?? null, url: null }));
---

<BaseLayout
  type="blog"
  title={title ?? ""}
  description={description ?? ""}
  seo={seo}
  ogImageUrl={ogImageUrl}
  pubDate={pubDate ?? undefined}
  authors={authorsList}
  alternatePaths={alternatePaths}
>
  <article class="site-container pt-36 md:pt-44">
    <div class="flex w-full flex-col items-center">
      <div class="mx-auto flex w-full max-w-[800px]">
        <div class="mx-auto text-center">
          <!-- Categories -->
          {
            categories && (
              <div class="flex justify-center gap-4">
                {categories.map((cat) => (
                  <a
                    href={cat.urlPath}
                    class="button button--ghost px-2 py-0.5 font-medium md:px-4 md:py-1"
                  >
                    {cat.title}
                  </a>
                ))}
              </div>
            )
          }

          <!-- title -->
          <h1 class="h1 mt-8">{title}</h1>

          <div class="mt-6 flex w-full flex-wrap justify-center gap-4">
            <!-- author info -->
            {
              authors?.map((author) => (
                <div class="mb-auto flex">
                  {author.avatar?.asset && (
                    <SanityImage
                      image={{
                        ...author.avatar,
                        alt: author.avatar.alt ?? `${author.name} avatar`,
                      }}
                      width={56}
                      aspectRatio="vierkant"
                      class="h-7 w-7 rounded-full object-cover"
                    />
                  )}
                  <div class="my-auto ml-2 opacity-80">{author.name}</div>
                </div>
              ))
            }

            {authors && authors.length > 0 && pubDate && <span>&bull;</span>}

            <!-- Date -->
            {
              pubDate && (
                <time class="my-auto h-full opacity-80" datetime={pubDate}>
                  {formatDate(new Date(pubDate), currLocale)}
                </time>
              )
            }
          </div>
        </div>
      </div>

      <!-- blog post main image -->
      {
        heroImage?.asset && (
          <div class="mt-6 max-w-[1000px] overflow-hidden">
            <SanityImage
              image={heroImage}
              sizesType="background"
              loading="eager"
              fetchpriority="high"
              class="max-h-[70vh] rounded-xl object-cover"
            />
          </div>
        )
      }
    </div>

    <!-- article content -->
    <div class="mt-10 w-full">
      <div class="mx-auto max-w-2xl">
        <div class="text-base-content text-base">
          <section id="blog-post-content" class="markdown-content mx-auto">
            <BlockRenderer blocks={blocks ?? []} />
          </section>

          <div class="mt-16 flex justify-center">
            <Button
              variant="outline"
              href={localeDefinition.localeSlug
                ? `/${localeDefinition.localeSlug}/${localeDefinition.blogSlug}`
                : `/${localeDefinition.blogSlug}`}
              arrow="left"
              class="py-2"
            >
              {backToAllPosts}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
