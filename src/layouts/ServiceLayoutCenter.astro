---
/**
 * * Centered services page layout. This has a title, description, main text, and an image if desired
 * The CTA and any other sections can be added in here so that all services pages have them
 */
// main layout
import BaseLayout from "./BaseLayout.astro";

// components
import HeadingWithImageSection from "@components/HeadingWithImage/HeadingWithImageSection.astro";
import CtaCardCenterSection from "@components/Cta/CtaCardCenterSection.astro";

interface Props {
  title: string;
  description: string;
  image?: any;
  alternatePaths?: Partial<Record<string, string>>;
}

const { title, description, image = undefined, alternatePaths } = Astro.props as Props;
---

<BaseLayout title={title} description={description} alternatePaths={alternatePaths}>
  <HeadingWithImageSection
    _type="headingWithImage"
    _key="layout-heading"
    title={title}
    image={image}
  />

  <!-- service details -->
  <section class="bg-base-200/50 my-20 py-12 md:py-20">
    <div class="markdown-content mx-auto max-w-[800px] px-4">
      <slot />
    </div>
  </section>

  <CtaCardCenterSection {...{ _type: "ctaCardCenter" } as any} />
</BaseLayout>
