---
import { SEO } from "astro-seo";

import jsonLDGenerator, { type FaqItem } from "@/utils/jsonLD";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getCompanyInfo } from "@/utils/companyInfo";

import HrefLang from "./HrefLang.astro";

const DEFAULT_IMAGE_PATH = "/images/cosmic-themes-logo.jpg";

const currLocale = getLocaleFromUrl(Astro.url);
const companyInfo = await getCompanyInfo(currLocale);

interface BaseProps {
  title: string;
  description: string;
  noindex?: boolean;
  alternatePaths?: Partial<Record<string, string>>;
  blocks?: any[];
}

interface GenProps extends BaseProps {
  type: "general";
  ogImageUrl?: string;
}

interface BlogProps extends BaseProps {
  type: "blog";
  ogImageUrl?: string;
  pubDate: string;
  authors: { name?: string | null; url?: string | null }[];
}

const {
  type,
  title,
  description,
  ogImageUrl,
  noindex = false,
  alternatePaths,
  blocks,
} = Astro.props as GenProps | BlogProps;

let jsonLD: string | undefined;
const siteBase = new URL(companyInfo?.baseUrl ?? Astro.site ?? "");
const canonicalUrl = new URL(Astro.url.pathname, siteBase);

function trimEndSlash(str: string) {
  return str.endsWith("/") ? str.slice(0, -1) : str;
}

const imageUrl = ogImageUrl ?? trimEndSlash(siteBase.toString()) + DEFAULT_IMAGE_PATH;

// if this is a blog page we do things differently
if (type === "blog") {
  const { pubDate, authors } = Astro.props as BlogProps;

  jsonLD = jsonLDGenerator({
    type: "blog",
    title,
    description,
    pubDate,
    ogImageUrl,
    authors,
    canonicalUrl,
  });
}
// for general pages
else {
  jsonLD = jsonLDGenerator({
    type: "general",
    siteTitle: companyInfo?.name ?? "",
  });
}

// FAQ JSON-LD — collect all faq items from faqAccordions and faqCards blocks
let faqJsonLD: string | null = null;
if (blocks?.length) {
  const faqItems: FaqItem[] = blocks
    .filter((b) => b._type === "faqAccordions" || b._type === "faqCards")
    .flatMap((b) => b.faqs ?? []);
  if (faqItems.length > 0) {
    faqJsonLD = jsonLDGenerator({ type: "faq", items: faqItems });
  }
}
---

<SEO
  title={title}
  description={description}
  canonical={canonicalUrl.toString()}
  openGraph={{
    basic: {
      title: title,
      type: type === "blog" ? "article" : "website",
      image: imageUrl,
      url: canonicalUrl.toString(),
    },
    optional: {
      description: description,
      siteName: companyInfo?.name,
    },
    image: {
      type: "image/webp",
      width: 1200,
      height: 630,
      alt: title,
    },
  }}
  twitter={{
    site: "",
    creator: "",
    card: "summary_large_image",
    title: title,
    description: description,
    image: imageUrl,
  }}
  noindex={noindex}
  nofollow={noindex}
/>

<!-- hreflang attributes -->
<HrefLang alternatePaths={alternatePaths} />

<!-- JSON LD -->
<Fragment set:html={jsonLD} />
{faqJsonLD && <Fragment set:html={faqJsonLD} />}
