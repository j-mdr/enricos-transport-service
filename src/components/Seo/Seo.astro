---
import { getImage } from "astro:assets";
import { type CollectionEntry } from "astro:content";
import { SEO } from "astro-seo";

import jsonLDGenerator from "@/utils/jsonLD";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getCompanyInfo } from "@/utils/companyInfo";

import HrefLang from "./HrefLang.astro";

const DEFAULT_IMAGE = { src: "/images/cosmic-themes-logo.jpg", alt: "Enrico's Transportservice" };

const currLocale = getLocaleFromUrl(Astro.url);
const companyInfo = await getCompanyInfo(currLocale);

interface BaseProps {
  title: string;
  description: string;
  noindex?: boolean;
  alternatePaths?: Partial<Record<string, string>>;
}

interface GenProps extends BaseProps {
  type: "general";
  image?: ImageMetadata;
}

interface BlogProps extends BaseProps {
  type: "blog";
  image: ImageMetadata;
  authors: CollectionEntry<"authors">[];
  postFrontmatter: CollectionEntry<"blog">["data"];
}

const {
  type,
  title,
  description,
  image,
  noindex = false,
  alternatePaths,
} = Astro.props as GenProps | BlogProps;

let optimizedImage;
let jsonLD;
const siteBase = new URL(companyInfo?.baseUrl ?? Astro.site ?? "");
const canonicalUrl = new URL(Astro.url.pathname, siteBase);

if (image) {
  optimizedImage = await getImage({
    src: image,
    format: "webp",
    quality: "high",
    width: 1200,
  });
}

// if this is a blog page we do things differently
if (type === "blog") {
  const { authors, postFrontmatter } = Astro.props as BlogProps;

  const jsonldImage = optimizedImage ?? DEFAULT_IMAGE;

  jsonLD = jsonLDGenerator({
    type: "blog",
    postFrontmatter: postFrontmatter,
    image: jsonldImage,
    authors: authors,
    canonicalUrl: canonicalUrl,
  });
}
// for general pages
else {
  jsonLD = jsonLDGenerator({
    type: "general",
    siteTitle: companyInfo?.title ?? "",
  });
}

function trimEndSlash(str: string) {
  if (str[str.length - 1] === "/") {
    return str.slice(0, -1);
  } else {
    return str;
  }
}

// put together the image URL
const imageUrl = trimEndSlash(siteBase.toString()) + (optimizedImage?.src || DEFAULT_IMAGE.src);
---

<SEO
  title={title}
  description={description}
  canonical={canonicalUrl.toString()}
  openGraph={{
    basic: {
      title: title,
      type: "website",
      image: imageUrl,
      url: canonicalUrl.toString(),
    },
    optional: {
      description: description,
      siteName: companyInfo?.title,
    },
    image: {
      type: "image/webp",
      width: optimizedImage?.attributes.width || "1200",
      height: optimizedImage?.attributes.height || "800",
      alt: title,
    },
  }}
  twitter={{
    site: "",
    creator: "",
    card: "summary_large_image",
    title: title,
    description: description,
    image: imageUrl,
  }}
  noindex={noindex}
  nofollow={noindex}
/>

<!-- hreflang attributes -->
<HrefLang alternatePaths={alternatePaths} />

<!-- JSON LD -->
<Fragment set:html={jsonLD} />
