---
import { locales, defaultLocale } from "@/config/siteSettings.json";

interface Props {
  alternatePaths?: Partial<Record<string, string>>;
}

const { alternatePaths } = Astro.props;

const localizedPaths = Object.fromEntries(
  locales.map((lang) => [lang, alternatePaths?.[lang] || "/"]),
);
---

{
  locales.length > 1 &&
    locales.map((lang) => (
      <>
        <link rel="alternate" hreflang={lang} href={Astro.url.origin + localizedPaths[lang]} />
        {lang === defaultLocale && (
          <link
            rel="alternate"
            hreflang="x-default"
            href={Astro.url.origin + localizedPaths[defaultLocale]}
          />
        )}
      </>
    ))
}
