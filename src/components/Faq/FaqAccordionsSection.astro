---
/**
 * * FAQ section in accordions
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import Accordion from "@components/Accordion/Accordion.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "faqAccordions" }>;

const { title = "", faqs = [] } = Astro.props;

if (!title || !faqs.length) return;

const mid = Math.ceil(faqs.length / 2);
const faqCols = [faqs.slice(0, mid), faqs.slice(mid)];

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="faq1" class="site-container my-20 md:my-28 lg:my-36">
  <h2 class="h2 text-center">
    {leadingText}
    {
      hasHighlightedWord && (
        <span class="relative whitespace-nowrap">
          {highlightedWord}
          <span>
            <Icon
              name="stellar/freehand-zig-underline"
              class="text-primary-500 absolute top-2 left-0 -z-10 h-full w-full translate-y-1/2"
              aria-hidden="true"
            />
          </span>
        </span>
      )
    }
    {trailingText ?? null}
  </h2>
  <div class="mx-auto mt-14 grid gap-x-10 gap-y-3 md:mt-16 lg:mt-20 lg:grid-cols-2">
    {
      faqCols.map((faqCol) => (
        <div class="flex w-full flex-col gap-3">
          {faqCol.map(({ question, answer }) => (
            <Accordion title={question ?? ""} details={answer ?? ""} />
          ))}
        </div>
      ))
    }
  </div>
</section>
