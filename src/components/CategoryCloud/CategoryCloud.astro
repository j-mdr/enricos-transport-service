---
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getAllCategories } from "@lib/groq/blogPost";

interface Props {
  showCount?: boolean;
}

const { showCount = false } = Astro.props as Props;

const currLocale = getLocaleFromUrl(Astro.url);
const categories = await getAllCategories(currLocale);
---

<div class="flex flex-wrap justify-center gap-x-4 gap-y-2">
  {
    categories.map((cat) => (
      <a href={cat.urlPath} class="button button--ghost py-2 text-sm">
        {cat.title}
      </a>
    ))
  }
</div>
