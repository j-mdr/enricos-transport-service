---
import { Icon } from "astro-icon/components";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import type { SanityImageObject } from "@lib/sanityImage";

interface Props {
  image?: SanityImageObject | null;
  name: string;
  title?: string;
  bio?: string;
}

const { image, name, title, bio } = Astro.props;
---

<div
  class="border-base-300 bg-base-50 flex flex-col items-center justify-between rounded-xl border px-4 py-6 text-center shadow-md md:py-8"
>
  <div class="flex flex-col items-center">
    {
      image?.asset ? (
        <SanityImage
          image={image}
          width={320}
          height={320}
          sizesType="avatar"
          loading="lazy"
          class="border-primary-500 aspect-square max-w-[clamp(6rem,20vmin,10rem)] rounded-full border-2 object-cover"
        />
      ) : (
        <div class="border-primary-500 bg-base-200 flex aspect-square w-full max-w-[clamp(6rem,20vmin,10rem)] items-center justify-center rounded-full border-2">
          <Icon name="tabler/user" class="h-12 w-12 opacity-60" aria-hidden="true" />
        </div>
      )
    }
    <p class="mt-4 text-lg">{name}</p>
    {title && <p class="opacity-80">{title}</p>}
    {bio && <p class="mt-4">{bio}</p>}
  </div>
</div>
