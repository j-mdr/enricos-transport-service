---
/**
 * * Alternating side service cards with titles, text, and images
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import ServiceCard from "@components/ServiceCard/ServiceCardSideImage.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "servicesSideImage" }>;

const { title = "", services = [] } = Astro.props;

if (!title || !services.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="services-side-image" class="overflow-hidden py-12">
  <div class="site-container">
    <div class="mx-auto flex max-w-2xl justify-center text-center">
      <h2 class="h2 relative z-20 mx-4">
        <div class="absolute top-0 left-0 hidden md:block">
          <Icon
            name="stellar/freehand-arrow-curl"
            class="text-primary-500 h-auto w-24 -translate-x-24 translate-y-12 -scale-x-100 -rotate-[45deg]"
            aria-hidden="true"
          />
        </div>
        {leadingText}
        {hasHighlightedWord && <span class="text-primary-600">{highlightedWord}</span>}
        {trailingText}
      </h2>
    </div>
    <div class="mt-10 flex flex-col gap-16 md:mt-16 md:gap-24">
      {
        services.map((service, idx) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            image={service.image}
            ctaButton={service.ctaButton}
            imageSide={idx % 2 === 0 ? "right" : "left"}
            idx={idx}
          />
        ))
      }
    </div>
  </div>
</section>
