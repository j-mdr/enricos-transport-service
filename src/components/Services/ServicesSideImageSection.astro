---
/**
 * * These are alternating side cards with titles, text, and images
 * Recommend using 2 or 3 cards in a row
 */
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import ServiceCard from "@components/ServiceCard/ServiceCardSideImage.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { ServicesSideImageSectionData } from "@config/configDataTypes.ts";
import { servicesSideImageData } from "./servicesSideImageData";

interface Props extends Partial<ServicesSideImageSectionData> {
  servicesSet?: string;
}

const { title: propTitle, services: propServices, servicesSet } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);
const staticData = servicesSideImageData[currLocale];

// Load from collection when servicesSet is provided, fallback to static data
const entries = servicesSet !== undefined ? await getCollection("servicesSideImage") : [];
const collectionEntry =
  servicesSet !== undefined
    ? (entries.find((e) => e.id === `${currLocale}/${servicesSet}`) ?? null)
    : null;

if (servicesSet !== undefined && !collectionEntry) return;

const title = collectionEntry ? collectionEntry.data.title : (propTitle ?? staticData.title);

const services = collectionEntry
  ? collectionEntry.data.services
      .filter((s) => s.image)
      .map((s) => ({
        image: { src: s.image!, alt: s.imageAlt },
        ctaButton: { href: s.ctaButtonHref, text: s.ctaButtonText },
        title: s.title,
        description: s.description,
      }))
  : (propServices ?? staticData.services);

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="services-side-image" class="overflow-hidden py-12">
  <div class="site-container">
    <div class="mx-auto flex max-w-2xl justify-center text-center">
      <h2 class="h2 relative z-20 mx-4">
        <div class="absolute top-0 left-0 hidden md:block">
          <Icon
            name="stellar/freehand-arrow-curl"
            class="text-primary-500 h-auto w-24 -translate-x-24 translate-y-12 -scale-x-100 -rotate-[45deg]"
            aria-hidden="true"
          />
        </div>
        {leadingText}
        {hasHighlightedWord && <span class="text-primary-600">{highlightedWord}</span>}
        {trailingText}
      </h2>
    </div>
    <div class="mt-10 flex flex-col gap-16 md:mt-16 md:gap-24">
      {
        services.map((service, idx) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            image={service.image}
            ctaButton={service.ctaButton}
            imageSide={idx % 2 === 0 ? "right" : "left"}
            idx={idx}
          />
        ))
      }
    </div>
  </div>
</section>
