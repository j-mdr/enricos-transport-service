---
/**
 * * Service cards with icons, titles, and text
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import ServiceCardIcon from "@components/ServiceCard/ServiceCardIcon.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "servicesIcon" }>;

const { title = "" } = Astro.props;
const services = Astro.props.services ?? [];

if (!title || !services.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="services-icon" class="bg-base-200/50 py-20 md:py-28 lg:py-36">
  <div class="site-container">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="h2">
        {leadingText}
        {hasHighlightedWord && <span class="text-primary-600">{highlightedWord}</span>}
        {trailingText}
      </h2>
    </div>
    <div
      class="mt-14 grid gap-4 sm:grid-cols-2 md:mt-16 md:grid-cols-3 lg:mt-20"
      id="services-icon-cards"
    >
      {
        services.map((service, idx) => (
          <ServiceCardIcon
            title={service.title ?? ""}
            description={service.description ?? undefined}
            icon={service.icon ?? ""}
            ctaButton={service.ctaButton as any}
            idx={idx}
            data-mos="fade-up"
            data-mos-delay={0.15 * idx}
            data-mos-anchor="#services-icon-cards"
          />
        ))
      }
    </div>
  </div>
</section>
