---
/**
 * * These are larger cards with icons, titles, and text
 * Recommend using minimum 3 cards in a row, although this should work for any number of cards
 * These smaller cards work great if there are a large amount of services to advertise
 *
 * ! If you can an error for an icon like "Error: Not Found: "calendar-check" in pack "tabler",
 * ! You can copy to actual SVG into src/icons, name it whatever, and use similar to below example "tabler/calendar-check"
 */

import { getCollection } from "astro:content";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { ServicesIconSectionData } from "@config/configDataTypes.ts";
import { servicesIconData } from "./servicesIconData";

// components
import ServiceCardIcon from "@components/ServiceCard/ServiceCardIcon.astro";

interface Props extends Partial<ServicesIconSectionData> {
  servicesSet?: string;
}

const { title: propTitle, services: propServices, servicesSet } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);
const staticData = servicesIconData[currLocale];

// Load from collection when servicesSet is provided, fallback to static data
const entries = servicesSet !== undefined ? await getCollection("servicesIcon") : [];
const collectionEntry =
  servicesSet !== undefined
    ? (entries.find((e) => e.id === `${currLocale}/${servicesSet}`) ?? null)
    : null;

if (servicesSet !== undefined && !collectionEntry) return;

const title = collectionEntry ? collectionEntry.data.title : (propTitle ?? staticData.title);

const services = collectionEntry
  ? collectionEntry.data.services.map((s) => ({
      icon: s.icon,
      title: s.title,
      description: s.description,
      ctaButton: { href: s.ctaButtonHref, text: s.ctaButtonText },
    }))
  : (propServices ?? staticData.services);

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="services-icon" class="bg-base-200/50 my-12 py-20 md:my-24">
  <div class="site-container">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="h2">
        {leadingText}
        {hasHighlightedWord && <span class="text-primary-600">{highlightedWord}</span>}
        {trailingText}
      </h2>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 md:grid-cols-3" id="services-icon-cards">
      {
        services.map((feature, idx) => (
          <ServiceCardIcon
            title={feature.title}
            description={feature.description}
            icon={feature.icon}
            ctaButton={feature.ctaButton}
            idx={idx}
            data-mos="fade-up"
            data-mos-delay={0.15 * idx}
            data-mos-anchor="#services-icon-cards"
          />
        ))
      }
    </div>
  </div>
</section>
