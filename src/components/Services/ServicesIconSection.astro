---
/**
 * * Service cards with icons, titles, and text
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import ServiceCardIcon from "@components/ServiceCard/ServiceCardIcon.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";

interface Props {
  title?: string;
  services?: {
    icon?: string;
    title: string;
    description?: string;
    ctaButton?: { link?: { text?: string; href?: string } };
  }[];
  [key: string]: any;
}

const { title = "", services = [] } = Astro.props;

if (!title || !services.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="services-icon" class="bg-base-200/50 my-12 py-20 md:my-24">
  <div class="site-container">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="h2">
        {leadingText}
        {hasHighlightedWord && <span class="text-primary-600">{highlightedWord}</span>}
        {trailingText}
      </h2>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 md:grid-cols-3" id="services-icon-cards">
      {
        services.map((service, idx) => (
          <ServiceCardIcon
            title={service.title}
            description={service.description}
            icon={service.icon}
            ctaButton={{
              href: service.ctaButton?.link?.href ?? "#",
              text: service.ctaButton?.link?.text ?? "",
            }}
            idx={idx}
            data-mos="fade-up"
            data-mos-delay={0.15 * idx}
            data-mos-anchor="#services-icon-cards"
          />
        ))
      }
    </div>
  </div>
</section>
