---
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import Button from "@components/Button/Button.astro";
import ContactInformationBlock from "@components/Contact/ContactInformationBlock.astro";
import SocialIcon from "@components/Social/SocialIcon.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getFooterData } from "@/utils/footer";
import { getCompanyInfo } from "@/utils/companyInfo";

const currLocale = getLocaleFromUrl(Astro.url);
const { ctaButton, columns } = await getFooterData(currLocale);
const companyInfo = await getCompanyInfo(currLocale);
const companyName = companyInfo?.name ?? "Enrico's Transportservice";
const today = new Date();
---

<footer class="site-container border-t-base-300 mt-20 mb-16 border-t">
  <div class="grid w-full justify-between gap-4 md:grid-cols-2">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="mt-6 flex flex-col items-start gap-4">
        <SiteLogo />
        <div class="">
          <Button variant="primary" href={ctaButton.href}>{ctaButton.text}</Button>
        </div>
        <div class="hidden text-sm opacity-80 md:block">
          &copy; {today.getFullYear()}
          {" "}{companyName} ©
        </div>
      </div>
      <!-- Contact info -->
      <div class="flex flex-col">
        <ContactInformationBlock />
      </div>
    </div>

    <div class="flex items-center md:justify-end">
      <!-- Link kolommen -->
      {columns.length > 0 && (
        <div class="flex gap-8">
          {columns.map((col: { title: string; links: { text: string; href: string }[] }) => (
            <div class="flex flex-col gap-2">
              <p class="font-semibold">{col.title}</p>
              {col.links.map((link) => (
                <a href={link.href} class="text-sm opacity-80 hover:opacity-100">{link.text}</a>
              ))}
            </div>
          ))}
        </div>
      )}

      <!-- Socials -->
      <div class="flex gap-2 ml-8">
        {companyInfo?.facebookUrl && (
          <SocialIcon href={companyInfo.facebookUrl} icon="tabler/facebook" social="Facebook" />
        )}
        {companyInfo?.instagramUrl && (
          <SocialIcon href={companyInfo.instagramUrl} icon="tabler/instagram" social="Instagram" />
        )}
        {companyInfo?.linkedinUrl && (
          <SocialIcon href={companyInfo.linkedinUrl} icon="tabler/linkedin" social="LinkedIn" />
        )}
      </div>
    </div>
  </div>
  <div class="mt-6 text-sm opacity-80 md:hidden">
    &copy; {today.getFullYear()}
    {" "}{companyName} ©
  </div>
</footer>