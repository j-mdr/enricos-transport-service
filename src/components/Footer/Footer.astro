---
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import Button from "@components/Button/Button.astro";
import ContactInformationBlock from "@components/Contact/ContactInformationBlock.astro";
import SocialIcon from "@components/Social/SocialIcon.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getFooterData } from "@/utils/footer";
import { getCompanyInfo } from "@/utils/companyInfo";

const currLocale = getLocaleFromUrl(Astro.url);
const resolved = await getFooterData(currLocale);
const logo = resolved?.logo ?? null;
const ctaButton = resolved?.ctaButton;
const columns = resolved?.columns ?? [];
const companyInfo = await getCompanyInfo(currLocale);
const companyName = companyInfo?.name ?? "Enrico's Transportservice";
const today = new Date();
---

<footer class="site-container border-t-base-300 mt-20 mb-16 border-t pt-10">
  <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[auto_auto_1fr_auto]">
    <!-- Logo + CTA -->
    <div class="flex flex-col gap-4">
      <SiteLogo logo={logo} />
      <Button
        variant={(ctaButton?.variant as any) ?? "primary"}
        link={ctaButton?.link ?? undefined}
      >
        {ctaButton?.link?.text}
      </Button>
      <div class="text-sm opacity-60">
        &copy; {today.getFullYear()} {companyName}
      </div>
    </div>

    <!-- Contact info -->
    <ContactInformationBlock />

    <!-- Link columns -->
    {
      columns.length > 0 && (
        <div class="grid auto-cols-max grid-flow-col gap-8">
          {columns.map((col: { title: string; links: { text: string; href: string; newTab?: boolean }[] }) => (
            <div class="flex flex-col gap-2">
              <h3 class="mb-1 text-sm font-medium">{col.title}</h3>
              {col.links.map((link) => (
                <a
                  href={link.href}
                  class="text-sm opacity-70 hover:opacity-100"
                  target={link.newTab ? "_blank" : undefined}
                  rel={link.newTab ? "noopener noreferrer" : undefined}
                >
                  {link.text}
                </a>
              ))}
            </div>
          ))}
        </div>
      )
    }

    <!-- Socials -->
    <div class="flex items-start gap-2">
      {
        companyInfo?.facebookUrl && (
          <SocialIcon href={companyInfo.facebookUrl} icon="tabler/brand-facebook" social="Facebook" />
        )
      }
      {
        companyInfo?.instagramUrl && (
          <SocialIcon href={companyInfo.instagramUrl} icon="tabler/brand-instagram" social="Instagram" />
        )
      }
      {
        companyInfo?.linkedinUrl && (
          <SocialIcon href={companyInfo.linkedinUrl} icon="tabler/brand-linkedin" social="LinkedIn" />
        )
      }
    </div>
  </div>


</footer>
