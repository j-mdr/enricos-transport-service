---
/**
 * * CTA with background image, title (with highlight), description, and button
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import SanityCtaButton from "@components/SanityCtaButton/SanityCtaButton.astro";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "ctaBgImage" }>;

const { title = "", description, ctaButton, image } = Astro.props;

if (!title) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="cta" class="text-base-100 relative my-20 md:my-32">
  <div class="relative">
    <!-- background image -->
    <div class="bg-base-900 absolute -z-20 h-full w-full">
      <div class="relative mx-auto h-full max-w-[2000px]">
        {
          image?.asset && (
            <SanityImage
              image={image}
              width={2000}
              height={1200}
              sizesType="background"
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover opacity-30"
            />
          )
        }
        <!-- left fade-out -->
        <div
          class="from-base-900 absolute top-0 -left-px z-10 h-full w-[10%] bg-gradient-to-r from-10% to-transparent"
        >
        </div>
        <!-- right fade-out -->
        <div
          class="to-base-900 absolute top-0 -right-px z-10 h-full w-[10%] bg-gradient-to-r from-transparent to-90%"
        >
        </div>
      </div>
    </div>

    <div class="site-container relative py-32">
      <div class="relative z-10 flex p-1">
        <div class="rounded-xl px-4 py-20">
          <div class="mx-auto max-w-2xl">
            <h2 class="h1">
              {leadingText}
              {
                hasHighlightedWord && (
                  <span class="relative whitespace-nowrap">
                    {highlightedWord}
                    <span>
                      <Icon
                        name="stellar/freehand-zig-underline"
                        class="text-primary-400 absolute top-1 left-0 -z-10 h-full w-full translate-y-1/2"
                        aria-hidden="true"
                      />
                    </span>
                  </span>
                )
              }
              {trailingText ?? null}
            </h2>
            {description && <p class="description mt-6">{description}</p>}
            <div class="text-base-900 mt-10 flex">
              <SanityCtaButton ctaButton={ctaButton} arrow="right" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
