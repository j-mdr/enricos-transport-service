---
/**
 * * CTA with background image, title (with highlight), description, and button
 * Data is managed via Keystatic CMS (ctaBgImage collection)
 */
import { getCollection } from "astro:content";
import { getLocalizedRoute } from "@/utils/translationUtils";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

// components
import Button from "@components/Button/Button.astro";

// utils
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { splitTitleWithIcon } from "@utils/textUtils.ts";

interface Props {
  ctaSet?: string;
}

const { ctaSet = "home" } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);

const ctaEntries = await getCollection("ctaBgImage");
const entry = ctaEntries.find((e) => e.id === `${currLocale}/${ctaSet}`);
if (!entry) return;

const { title, description, ctaButtonText, ctaButtonHref } = entry.data;
const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);

import image from "@images/enricos-transportservice-bestelbus-achteraanzicht-zonsondergang-rivier-1x1.jpeg";
---

<section id="cta" class="text-base-100 relative my-20">
  <div class="relative">
    <!-- background image -->
    <div class="bg-base-900 absolute -z-20 h-full w-full">
      <div class="relative mx-auto h-full max-w-[2000px]">
        <Image
          src={image}
          class="absolute inset-0 h-full w-full object-cover opacity-30"
          alt="smiling family"
          aria-hidden="true"
          loading="lazy"
          height={2000}
        />

        <!-- left fade-out -->
        <div
          class="from-base-900 absolute top-0 -left-px z-10 h-full w-[10%] bg-gradient-to-r from-10% to-transparent"
        >
        </div>
        <!-- right fade-out -->
        <div
          class="to-base-900 absolute top-0 -right-px z-10 h-full w-[10%] bg-gradient-to-r from-transparent to-90%"
        >
        </div>
      </div>
    </div>

    <div class="site-container relative py-32">
      <!-- center card -->
      <div class="relative z-10 flex p-1">
        <div class="rounded-xl px-4 py-20">
          <div class="mx-auto max-w-2xl">
            <h2 class="h1">
              {leadingText}
              {
                hasHighlightedWord && (
                  <span class="relative whitespace-nowrap">
                    {highlightedWord}
                    <span>
                      <Icon
                        name="stellar/freehand-zig-underline"
                        class="text-primary-400 absolute top-0 left-0 -z-10 h-full w-full translate-y-1/2"
                        aria-hidden="true"
                      />
                    </span>
                  </span>
                )
              }
              {trailingText ?? null}
            </h2>
            <p class="description mt-6">{description}</p>
            <div class="text-base-900 mt-10 flex">
              <Button
                variant="primary"
                href={getLocalizedRoute(currLocale, ctaButtonHref)}
                arrow="right"
              >
                {ctaButtonText}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
