---
/**
 * * CTA card with centered text and corner blobs
 * Data is managed via Keystatic CMS (ctaCard collection)
 */
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Button from "@components/Button/Button.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getLocalizedRoute } from "@/utils/translationUtils";
import { splitTitleWithIcon } from "@utils/textUtils.ts";

interface Props {
  ctaSet?: string;
}

const { ctaSet = "home" } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);

const ctaEntries = await getCollection("ctaCard");
const entry = ctaEntries.find((e) => e.id === `${currLocale}/${ctaSet}`);
if (!entry) return;

const { title, description, ctaButtonText, ctaButtonHref } = entry.data;
const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="cta" class="my-24 py-8 md:my-36">
  <div class="site-container">
    <div class="border-primary-300 relative h-full w-full overflow-hidden rounded-xl border">
      <!-- bottom left blob -->
      <Icon
        name="stellar/blob-1"
        class="text-primary-200/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] -translate-x-[50%] rotate-12"
        aria-hidden="true"
      />

      <!-- top left blob -->
      <Icon
        name="stellar/blob-2"
        class="text-primary-400/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] -translate-x-[50%] -translate-y-[50%] rotate-12"
        aria-hidden="true"
      />

      <!-- bottom right blob -->
      <Icon
        name="stellar/blob-2"
        class="text-primary-400/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] translate-x-[20%]"
        aria-hidden="true"
      />

      <!-- center card -->
      <div class="relative z-10 p-1">
        <div class="rounded-xl px-4 py-20 text-center">
          <div class="mx-auto max-w-2xl">
            <h2 class="h1">
              {leadingText}
              {
                hasHighlightedWord && (
                  <span class="relative whitespace-nowrap">
                    {highlightedWord}
                    <span>
                      <Icon
                        name="stellar/freehand-zig-underline"
                        class="text-primary-400 absolute top-0 left-0 -z-10 h-full w-full translate-y-1/2"
                        aria-hidden="true"
                      />
                    </span>
                  </span>
                )
              }
              {trailingText ?? null}
            </h2>
            <p class="description mt-6">
              {description}
            </p>
            <div class="mt-10 flex justify-center">
              <Button
                variant="primary"
                href={getLocalizedRoute(currLocale, ctaButtonHref)}
                arrow="right"
              >
                {ctaButtonText}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
