---
/**
 * * CTA card with centered text and corner blobs
 */
import { getLocalizedRoute } from "@/utils/translationUtils";
import { Icon } from "astro-icon/components";
import Button from "@components/Button/Button.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { getTranslatedData } from "@/utils/translationUtils";
import type { CtaCardCenterSectionData } from "@config/configDataTypes.ts";

const currLocale = getLocaleFromUrl(Astro.url);
const data = getTranslatedData("ctaCardCenterSectionData", currLocale);

type Props = Partial<CtaCardCenterSectionData>;

const {
  title = data.title,
  description = data.description,
  ctaButton = data.ctaButton,
} = Astro.props;

const localizedCtaButtonHref = getLocalizedRoute(currLocale, ctaButton.href);
---

<section id="cta" class="my-24 py-8 md:my-36">
  <div class="site-container">
    <div class="border-primary-300 relative h-full w-full overflow-hidden rounded-xl border">
      <!-- bottom left blob -->
      <Icon
        name="stellar/blob-1"
        class="text-primary-200/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] -translate-x-[50%] rotate-12"
        aria-hidden="true"
      />

      <!-- top left blob -->
      <Icon
        name="stellar/blob-2"
        class="text-primary-400/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] -translate-x-[50%] -translate-y-[50%] rotate-12"
        aria-hidden="true"
      />

      <!-- bottom right blob -->
      <Icon
        name="stellar/blob-2"
        class="text-primary-400/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] translate-x-[20%]"
        aria-hidden="true"
      />

      <!-- center card -->
      <div class="relative z-10 p-1">
        <div class="rounded-xl px-4 py-20 text-center">
          <div class="mx-auto max-w-2xl">
            <h2 class="h1">
              {title}
            </h2>
            <p class="description mt-6">
              {description}
            </p>
            <div class="mt-10 flex justify-center">
              <Button variant="primary" href={localizedCtaButtonHref} arrow="right">
                {ctaButton.text}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
