---
/**
 * * CTA with title, text, button, and cards on the side
 * Data is managed via Keystatic CMS (ctaCards collection)
 *
 * ! If you get an error for an icon like "Error: Not Found: "calendar-check" in pack "tabler",
 * ! You can copy the actual SVG into src/icons and name it however and use similar to below
 */
import { getCollection } from "astro:content";
import { getLocalizedRoute } from "@/utils/translationUtils";
import { splitTitleWithIcon } from "@utils/textUtils.ts";

// components
import FeatureCard from "@components/FeatureCard/FeatureCardMedium.astro";
import Button from "@components/Button/Button.astro";

// utils
import { getLocaleFromUrl } from "@/utils/localeUtils";

interface Props {
  ctaSet?: string;
}

const { ctaSet = "home" } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);

const ctaEntries = await getCollection("ctaCards");
const entry = ctaEntries.find((e) => e.id === `${currLocale}/${ctaSet}`);
if (!entry) return;

const { title, description, ctaButtonText, ctaButtonHref, cards } = entry.data;
const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="cta" class="bg-primary-100 my-20 py-20">
  <div class="site-container relative grid gap-10 md:grid-cols-2">
    <div class="mx-auto flex max-w-lg flex-col">
      <h2 class="h1 leading-tight">
        {leadingText}
        {hasHighlightedWord && <span class="relative whitespace-nowrap">{highlightedWord}</span>}
        {trailingText ?? null}
      </h2>
      <p class="description mt-6">
        {description}
      </p>
      <div class="flex">
        <Button
          variant="primary"
          href={getLocalizedRoute(currLocale, ctaButtonHref)}
          class="mt-6"
          arrow="right"
        >
          {ctaButtonText}
        </Button>
      </div>
    </div>
    <div class="mx-auto flex max-w-lg flex-col gap-8">
      {cards.map((card) => <FeatureCard title={card.title} text={card.text} icon={card.icon} />)}
    </div>
  </div>
</section>
