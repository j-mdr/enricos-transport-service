---
/**
 * * HeroCenteredSection with background blobs
 */
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Button from "@components/Button/Button.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { splitTitleWithIcon } from "@utils/textUtils.ts";

interface Props {
  heroSet?: string;
}

const { heroSet = "home" } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);

const heroCenteredEntries = await getCollection("heroCentered");
const entry = heroCenteredEntries.find((e) => e.id === `${locale}/${heroSet}`);
if (!entry) return;

const { title, description, ctaButton1Text, ctaButton1Href, ctaButton2Text, ctaButton2Href } =
  entry.data;
const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="hero" class="relative mb-14 flex w-full overflow-hidden pb-10">
  <!-- bottom left blob -->
  <Icon
    name="stellar/blob-1"
    class="text-primary-200/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] -translate-x-[50%] rotate-12"
    aria-hidden="true"
  />

  <!-- top left blob -->
  <Icon
    name="stellar/blob-2"
    class="text-primary-400/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] -translate-x-[50%] -translate-y-[50%] rotate-12"
    aria-hidden="true"
  />

  <!-- bottom right blob -->
  <Icon
    name="stellar/blob-2"
    class="text-primary-400/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] translate-x-[20%]"
    aria-hidden="true"
  />

  <!-- hero items -->
  <div class="site-container pt-40 pb-10 text-center md:pb-20 lg:pt-48 lg:pb-36">
    <div class="mx-auto max-w-[800px]">
      <h1
        class="text-4xl leading-tight font-medium md:text-5xl md:leading-tight"
        data-mos="fade-up"
      >
        {leadingText}
        {
          hasHighlightedWord ? (
            <span class="relative whitespace-nowrap">
              {highlightedWord}
              <span>
                <Icon
                  name="stellar/freehand-zig-underline"
                  class="text-primary-300 absolute top-0 left-0 -z-10 h-full w-full translate-y-1/2"
                  aria-hidden="true"
                />
              </span>
            </span>
          ) : null
        }
        {trailingText ?? null}
      </h1>
      {
        description && (
          <p class="description mt-6" data-mos="fade-up" data-mos-delay=".2">
            {description}
          </p>
        )
      }
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <Button variant="primary" href={ctaButton1Href} data-mos="fade-up" data-mos-delay=".9">
          {ctaButton1Text}
        </Button>
        {
          ctaButton2Text && ctaButton2Href && (
            <Button variant="outline" href={ctaButton2Href} data-mos="fade-up" data-mos-delay="1.1">
              {ctaButton2Text}
            </Button>
          )
        }
      </div>
    </div>
  </div>
</section>
