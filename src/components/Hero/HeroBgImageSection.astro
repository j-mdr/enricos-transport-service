---
/**
 * * HeroBgImageSection with background image
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import SanityCtaButton from "@components/SanityCtaButton/SanityCtaButton.astro";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "heroBgImage" }>;

const { title = "", description, ctaButton1, ctaButton2, image } = Astro.props;

if (!title) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="hero" class="relative mb-14 flex max-h-[80svh] min-h-[500px] w-full md:pb-22">
  <!-- background image -->
  {
    image?.asset && (
      <div class="absolute -z-20 h-full w-full overflow-hidden">
        <SanityImage
          image={image}
          width={2000}
          height={1500}
          sizesType="background"
          loading="eager"
          class="h-full w-full object-cover"
        />
      </div>
    )
  }

  <!-- gradient filter so text has even light bg -->
  <div
    class="absolute -z-10 h-full w-full bg-gradient-to-r from-white/90 via-white/50 to-white/50 md:to-transparent"
  >
  </div>

  <!-- hero items -->
  <div class="site-container w-full gap-10 pt-36 pb-24 md:pt-44 md:pb-36">
    <div class="mr-auto max-w-[450px]">
      <h1 class="text-4xl leading-tight font-medium sm:text-5xl md:leading-tight">
        {leadingText}
        {
          hasHighlightedWord ? (
            <span class="relative whitespace-nowrap">
              {highlightedWord}
              <span>
                <Icon
                  name="stellar/freehand-zig-underline"
                  class="text-primary-300 absolute top-1 left-0 -z-10 h-full w-full translate-y-1/2"
                  aria-hidden="true"
                />
              </span>
            </span>
          ) : null
        }
        {trailingText ?? null}
      </h1>
      {description && <p class="description mt-6">{description}</p>}
      {
        (ctaButton1?.link || ctaButton2?.link) && (
          <div class="mt-6 flex flex-wrap gap-4">
            <SanityCtaButton ctaButton={ctaButton1} />
            <SanityCtaButton ctaButton={ctaButton2} />
          </div>
        )
      }
    </div>
  </div>
</section>
