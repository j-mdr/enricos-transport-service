---
/**
 * * HeroBgImageSection with background image
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import SanityCtaButton from "@components/SanityCtaButton/SanityCtaButton.astro";
import type { SanityCtaButtonObject } from "@components/SanityCtaButton/SanityCtaButton.astro";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { SanityImageObject } from "@lib/sanityImage";

interface Props {
  title?: string;
  description?: string;
  ctaButton1?: SanityCtaButtonObject;
  ctaButton2?: SanityCtaButtonObject;
  image?: SanityImageObject | null;
  [key: string]: any;
}

const { title = "", description, ctaButton1, ctaButton2, image } = Astro.props;

if (!title) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="hero" class="relative mb-14 flex min-h-svh w-full md:pb-22">
  <!-- background image -->
  {
    image?.asset && (
      <div class="absolute -z-20 h-full w-full overflow-hidden">
        <SanityImage
          image={image}
          width={2000}
          height={1500}
          sizesType="background"
          loading="eager"
          class="h-full w-full object-cover"
        />
      </div>
    )
  }

  <!-- gradient filter so text has even light bg -->
  <div
    class="absolute -z-10 h-full w-full bg-gradient-to-r from-white/90 via-white/50 to-white/50 md:to-transparent"
  >
  </div>

  <!-- hero items -->
  <div class="site-container w-full gap-10 pt-36 pb-24 md:pt-44 md:pb-36">
    <div class="mr-auto max-w-[450px]">
      <h1
        class="text-4xl leading-tight font-medium sm:text-5xl md:leading-tight"
        data-mos="fade-up"
      >
        {leadingText}
        {
          hasHighlightedWord ? (
            <span class="relative whitespace-nowrap">
              {highlightedWord}
              <span>
                <Icon
                  name="stellar/freehand-zig-underline"
                  class="text-primary-300 absolute top-0 left-0 -z-10 h-full w-full translate-y-1/2"
                  aria-hidden="true"
                />
              </span>
            </span>
          ) : null
        }
        {trailingText ?? null}
      </h1>
      {
        description && (
          <p class="description mt-6" data-mos="fade-up" data-mos-delay=".2">
            {description}
          </p>
        )
      }
      {
        (ctaButton1?.link || ctaButton2?.link) && (
          <div class="mt-6 flex flex-wrap gap-4">
            <SanityCtaButton ctaButton={ctaButton1} data-mos="fade-up" data-mos-delay=".9" />
            <SanityCtaButton ctaButton={ctaButton2} data-mos="fade-up" data-mos-delay="1.1" />
          </div>
        )
      }
    </div>
  </div>
</section>
