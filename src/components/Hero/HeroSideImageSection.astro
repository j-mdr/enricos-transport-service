---
/**
 * * HeroSideImageSection with background blobs and side image
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import SanityCtaButton from "@components/SanityCtaButton/SanityCtaButton.astro";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "heroSideImage" }>;

const { title = "", description, ctaButton, image } = Astro.props;

if (!title) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="hero" class="relative mb-14 flex min-h-[60svh] w-full overflow-clip pb-10">
  <!-- Background -->
  <div class="absolute -z-10 h-full w-full">
    <svg
      class="text-primary-200/50 h-full w-full"
      viewBox="0 0 1800 1000"
      width="1800"
      height="1000"
      preserveAspectRatio="xMinYMin slice"
      xmlns="http://www.w3.org/2000/svg"
      xmlns:xlink="http://www.w3.org/1999/xlink"
      version="1.1"
      style="stroke:currentColor;fill:currentColor;"
    >
      <g transform="translate(1800, 1000)">
        <path
          d="M-950 0C-920.9 -120.4 -891.9 -240.9 -843.5 -349.4C-795.1 -457.9 -727.4 -554.5 -647 -647C-566.6 -739.5 -473.5 -827.9 -363.5 -877.7C-253.6 -927.5 -126.8 -938.7 0 -950L0 0Z"
        >
        </path>
      </g>
      <g>
        <path
          d="M950 0C926.3 119.5 902.6 239 861.1 356.7C819.6 474.3 760.3 590.1 671.8 671.8C583.2 753.4 465.5 801 348.6 841.7C231.8 882.3 115.9 916.2 0 950L0 0Z"
        >
        </path>
      </g>
    </svg>
  </div>

  <!-- hero items -->
  <div
    class="site-container mr-auto grid items-start gap-8 pt-36 pb-6 md:grid-cols-2 md:pt-44 md:pb-20"
  >
    <!-- Hero text -->
    <div class="mx-auto max-w-[450px] md:ml-0">
      <h1
        class="text-4xl leading-tight font-medium lg:text-5xl lg:leading-tight"
      >
        {leadingText}
        {
          hasHighlightedWord ? (
            <span class="relative whitespace-nowrap">
              {highlightedWord}
              <span>
                <Icon
                  name="stellar/freehand-zig-underline"
                  class="text-primary-300 absolute top-0 left-0 -z-10 h-full w-full translate-y-1/2"
                  aria-hidden="true"
                />
              </span>
            </span>
          ) : null
        }
        {trailingText ?? null}
      </h1>
      {
        description && (
          <p class="description mt-6">
            {description}
          </p>
        )
      }
      {
        ctaButton && (
          <div class="mt-6 flex gap-4">
            <SanityCtaButton ctaButton={ctaButton} />
          </div>
        )
      }
    </div>
    <!-- hero image -->
    {
      image?.asset && (
        <div class="mx-auto max-w-lg md:max-w-full">
          <SanityImage
            image={image}
            aspectRatio="klassiek"
            sizesType="half"
            loading="eager"
            class="rounded-xl"
          />
        </div>
      )
    }
  </div>
</section>
