---
import { urlFor, ASPECT_RATIOS, type SanityImageObject, type AspectRatio } from "@lib/sanityImage";

type SizesType = "background" | "half" | "card" | "avatar";

interface Props {
  image: SanityImageObject | null | undefined;
  width?: number;
  height?: number;
  aspectRatio?: AspectRatio;
  quality?: number;
  sizes?: string;
  sizesType?: SizesType;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  [key: string]: any;
}

const {
  image,
  width,
  height: heightProp,
  aspectRatio,
  quality = 70,
  sizes: sizesProp,
  sizesType,
  loading = "lazy",
  fetchpriority: fetchpriorityProp,
  class: className,
  ...rest
} = Astro.props;

// Srcset widths per sizesType — covers all viewports up to retina
const SRCSET_WIDTHS: Record<SizesType, number[]> = {
  background: [640, 960, 1280, 1920, 2560, 3200],
  half: [400, 640, 800, 1000, 1280, 1600, 2000],
  card: [320, 480, 640, 800, 1000, 1200],
  avatar: [], // handled via explicit width + width*2
};

const SIZES_PRESETS: Record<SizesType, string> = {
  background: "100vw",
  half: "(min-width: 1024px) 50vw, 100vw",
  card: "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw",
  avatar: width ? `${width}px` : "10vw",
};

const sizes =
  sizesProp ??
  (sizesType
    ? SIZES_PRESETS[sizesType]
    : width
      ? `(min-width: ${width}px) ${width}px, 100vw`
      : "100vw");

// Determine srcset widths to generate
const srcsetWidths: number[] =
  sizesType && sizesType !== "avatar"
    ? SRCSET_WIDTHS[sizesType]
    : width
      ? [width, Math.min(width * 2, 3200)]
      : [640, 1280, 1920];

// Default widths per sizesType for width/height HTML attributes (CLS prevention only — not used in URLs)
const SIZESTYPE_ATTR_WIDTHS: Record<SizesType, number> = {
  background: 1920,
  half: 800,
  card: 640,
  avatar: 80,
};

// Derived width/height for <img> attributes (prevents CLS)
const attrWidth = width ?? (sizesType ? SIZESTYPE_ATTR_WIDTHS[sizesType] : undefined);
const height =
  heightProp ??
  (aspectRatio && attrWidth ? Math.round(attrWidth / ASPECT_RATIOS[aspectRatio]) : undefined);

// fetchpriority: default to "high" for eager (LCP) images
const fetchpriority = fetchpriorityProp ?? (loading === "eager" ? "high" : undefined);

// decoding: sync for LCP images so the browser paints immediately after download
const decoding = loading === "eager" ? "sync" : "async";

// LQIP placeholder as CSS background — only for lazy-loaded raster images
const lqip = loading !== "eager" ? (image?.asset?.metadata?.lqip ?? null) : null;
const placeholderStyle = lqip ? `background-image:url(${lqip});background-size:cover;background-repeat:no-repeat;` : undefined;

if (!image?.asset) return;

const hasRef = !!(image.asset._ref || image.asset._id);

const isSvg = hasRef
  ? (image.asset._ref || image.asset._id || "").endsWith("-svg")
  : (image.asset.url ?? "").toLowerCase().endsWith(".svg");

const alt = image.alt ?? "";

// Build srcset for a given format, applying aspect ratio per entry
function buildSrcset(format: "webp" | "jpg"): string {
  return srcsetWidths
    .map((w) => {
      let b = urlFor(image!).format(format).quality(quality).width(w);
      if (aspectRatio) {
        b = b.height(Math.round(w / ASPECT_RATIOS[aspectRatio])).fit("crop");
      } else if (height && width) {
        b = b.height(Math.round((height / width) * w)).fit("crop");
      }
      return `${b.url()} ${w}w`;
    })
    .join(", ");
}

let srcFallback: string | undefined;
let srcsetWebp: string | undefined;
let srcsetJpeg: string | undefined;

if (hasRef) {
  if (isSvg) {
    srcFallback = urlFor(image).url();
  } else {
    let b = urlFor(image).format("jpg").quality(quality);
    if (width) b = b.width(width);
    if (height) b = b.height(height);
    if (width && height) b = b.fit("crop");
    srcFallback = b.url();
    srcsetWebp = buildSrcset("webp");
    srcsetJpeg = buildSrcset("jpg");
  }
} else {
  srcFallback = image.asset.url ?? "";
}
---

{
  isSvg ? (
    <img
      src={srcFallback}
      alt={alt}
      width={attrWidth}
      height={height}
      class={className}
      {...rest}
    />
  ) : srcsetWebp ? (
    <picture>
      <source type="image/webp" srcset={srcsetWebp} {sizes} />
      <source type="image/jpeg" srcset={srcsetJpeg} {sizes} />
      <img
        src={srcFallback}
        alt={alt}
        width={attrWidth}
        height={height}
        loading={loading}
        fetchpriority={fetchpriority}
        decoding={decoding}
        style={placeholderStyle}
        class={className}
        {...rest}
      />
    </picture>
  ) : (
    <img
      src={srcFallback}
      alt={alt}
      width={attrWidth}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding={decoding}
      style={placeholderStyle}
      class={className}
      {...rest}
    />
  )
}
