---
/**
 * * Toggleable image section — text on left, image on right
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "featureToggleImage" }>;

const { sectionTitle, sections = [] } = Astro.props;

if (!sectionTitle || !sections.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(sectionTitle);
---

<section id="feature-toggle-image" class="my-20 md:my-32">
  <div class="site-container">
    <div class="mx-auto grid gap-8 rounded-xl md:grid-cols-5 lg:gap-12">
      <div class="md:col-span-2">
        <h2 class="h2 relative inline">
          {leadingText}
          {
            hasHighlightedWord && (
              <span class="relative whitespace-nowrap">
                {highlightedWord}
                <span>
                  <Icon
                    name="stellar/freehand-zig-underline"
                    class="text-primary-400 absolute top-1 left-0 -z-10 h-full w-full translate-y-1/2"
                    aria-hidden="true"
                  />
                </span>
              </span>
            )
          }
          {trailingText ?? null}
          <Icon
            name="stellar/freehand-arrow"
            class="text-primary-500 absolute top-0 right-0 h-auto w-10 translate-x-10 translate-y-7 rotate-45"
            aria-hidden="true"
          />
        </h2>
        <div class="mt-6 flex flex-col gap-2">
          {
            sections.map((section, idx) => (
              <button
                id={`toggle-feature__toggle-${idx}`}
                class={`${
                  idx === 0 ? "toggle-feature__toggle--active" : ""
                } border-base-300 hover:border-primary-300 flex items-start justify-start gap-2 rounded-lg border p-2 transition duration-300 hover:opacity-100`}
              >
                {section.icon && (
                  <Icon name={section.icon} class="mt-1 h-5 w-5" aria-hidden="true" />
                )}
                <p class="text-start text-lg">{section.title}</p>
              </button>
            ))
          }
        </div>
      </div>

      <!-- images -->
      <div class="mx-auto max-w-4xl md:col-span-3">
        {
          sections.map((section, idx) =>
            section.image?.asset ? (
              <div id={`feature8__image-${idx}`} class={idx === 0 ? "" : "hidden"}>
                <SanityImage
                  image={section.image}
                  width={1200}
                  height={800}
                  sizesType="half"
                  loading={idx === 0 ? "eager" : "lazy"}
                  class="relative z-10 rounded-xl border border-transparent object-cover"
                />
              </div>
            ) : (
              <div
                id={`feature8__image-${idx}`}
                class={`${idx === 0 ? "" : "hidden"} relative z-10 flex aspect-video items-center justify-center rounded-xl border border-transparent bg-gray-100`}
              >
                <p class="text-muted-foreground text-sm">{section.title}</p>
              </div>
            ),
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  @import "tailwindcss/theme" theme(reference);
  @import "@/styles/tailwind-theme.css" theme(reference);

  .toggle-feature__toggle--active {
    @apply border-primary-300 ring-primary-500 ring-1;
  }
</style>

<script>
  function toggleFeatureSetup() {
    const toggleButtons = document.querySelectorAll(
      "[id^=toggle-feature__toggle-]",
    ) as NodeListOf<HTMLButtonElement>;
    const toggleImages = document.querySelectorAll(
      "[id^=feature8__image-]",
    ) as NodeListOf<HTMLDivElement>;

    toggleButtons?.forEach((button, idx) => {
      button.addEventListener("click", () => {
        toggleButtons?.forEach((b) => b.classList.remove("toggle-feature__toggle--active"));
        button.classList.add("toggle-feature__toggle--active");
        toggleImages.forEach((image) => image.classList.add("hidden"));
        toggleImages[idx]?.classList.remove("hidden");
      });
    });
  }

  toggleFeatureSetup();
  document.addEventListener("astro:after-swap", toggleFeatureSetup);
</script>
