---
/**
 * * Alternating side cards with titles, text, and images
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import FeatureCard from "@components/FeatureCard/FeatureCardSideImage.astro";
import { Icon } from "astro-icon/components";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "featureSideImage" }>;

const { sectionTitle, items = [] } = Astro.props;

if (!sectionTitle || !items.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(sectionTitle);
---

<section id="feature-side-image" class="my-16 overflow-hidden md:my-24 lg:my-32">
  <div class="site-container">
    <div class="mx-auto flex max-w-2xl justify-center text-center">
      <h2 class="h2 text-center">
        {leadingText}
        {
          hasHighlightedWord && (
            <span class="relative whitespace-nowrap">
              {highlightedWord}
              <span>
                <Icon
                  name="stellar/freehand-zig-underline"
                  class="text-primary-400 absolute top-0 left-0 -z-10 h-full w-full translate-y-1/2"
                  aria-hidden="true"
                />
              </span>
            </span>
          )
        }
        {trailingText ?? null}
      </h2>
    </div>
    <div class="mt-10 flex flex-col gap-12 md:mt-12 md:gap-20 lg:mt-16 lg:gap-24">
      {
        items
          .filter((item) => item.image?.asset)
          .map((item, idx) => (
            <FeatureCard
              title={item.title ?? ""}
              items={item.checkItems ?? []}
              image={item.image}
              imageSide={idx % 2 === 0 ? "right" : "left"}
              href={(item.link as any)?.destination?.[0]?.href}
              idx={idx}
            />
          ))
      }
    </div>
  </div>
</section>
