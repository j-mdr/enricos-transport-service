---
/**
 * * Alternating side cards with titles, text, and images
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import FeatureCard from "@components/FeatureCard/FeatureCardSideImage.astro";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "featureSideImage" }>;

const { sectionTitle, items = [] } = Astro.props;

if (!sectionTitle || !items.length) return;
---

<section id="feature-side-image" class="my-12 overflow-hidden py-12">
  <div class="site-container">
    <div class="mx-auto flex max-w-2xl justify-center text-center">
      <h2 class="h2 text-center">{sectionTitle}</h2>
    </div>
    <div class="mt-10 flex flex-col gap-16 md:mt-16 md:gap-24">
      {
        items
          .filter((item) => item.image?.asset)
          .map((item, idx) => (
            <FeatureCard
              title={item.title}
              items={item.checkItems ?? []}
              image={item.image}
              imageSide={idx % 2 === 0 ? "right" : "left"}
              href={item.link?.href}
              idx={idx}
            />
          ))
      }
    </div>
  </div>
</section>
