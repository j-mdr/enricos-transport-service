---
import { Icon } from "astro-icon/components";

interface Props {
  sectionTitle: string;
  titleHighlight?: string;
  youtubeUrl: string;
}

const { sectionTitle, titleHighlight, youtubeUrl } = Astro.props;

if (!sectionTitle || !youtubeUrl) return;

function getYoutubeEmbedUrl(url: string): string | null {
  const match = url.match(/(?:v=|youtu\.be\/)([^&?/]+)/);
  return match ? `https://www.youtube.com/embed/${match[1]}` : null;
}

function renderTitle(title: string, highlight?: string) {
  if (!highlight) return title;
  return title.replace(highlight, `<span class="text-primary-600">${highlight}</span>`);
}

const embedUrl = getYoutubeEmbedUrl(youtubeUrl);
---

{
  embedUrl && (
    <section id="feature-video" class="my-20 md:my-28 lg:my-36">
      <div class="site-container">
        <div class="mx-auto max-w-5xl">
          <div class="mx-auto flex max-w-lg justify-center text-center">
            <h2 class="h2 relative mx-4">
              <div class="absolute top-0 left-0 hidden sm:block">
                <Icon
                  name="stellar/freehand-arrow-curl"
                  class="text-primary-500 h-auto w-20 -translate-x-16 translate-y-10 -scale-x-100 -rotate-[40deg]"
                  aria-hidden="true"
                />
              </div>
              <Fragment set:html={renderTitle(sectionTitle, titleHighlight)} />
            </h2>
          </div>
          <div class="mx-auto mt-14 max-w-4xl md:mt-16 lg:mt-20">
            <iframe
              src={embedUrl}
              title={sectionTitle}
              class="aspect-video w-full rounded-xl"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>
  )
}
