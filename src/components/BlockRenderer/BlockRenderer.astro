---
/**
 * * BlockRenderer
 * Renders a blocks array from the Keystatic block builder.
 * Each block references an existing hero/faq collection entry or contains inline rich text.
 */
import HeroBgImageSection from "@components/Hero/HeroBgImageSection.astro";
import HeroSideImageSection from "@components/Hero/HeroSideImageSection.astro";
import HeroCenteredSection from "@components/Hero/HeroCenteredSection.astro";
import FaqAccordionsSection from "@components/Faq/FaqAccordionsSection.astro";
import FaqCardsSection from "@components/Faq/FaqCardsSection.astro";
import CtaBgImageSection from "@components/Cta/CtaBgImageSection.astro";
import CtaCardCenterSection from "@components/Cta/CtaCardCenterSection.astro";
import CtaCardCenter2Section from "@components/Cta/CtaCardCenter2Section.astro";
import CtaCardsSection from "@components/Cta/CtaCardsSection.astro";
import FeatureCardsSmallSection from "@components/Feature/FeatureCardsSmallSection.astro";
import FeatureLightboxMarqueeSection from "@components/Feature/FeatureLightboxMarqueeSection.astro";
import FeatureGalleryMarqueeSection from "@components/Feature/FeatureGalleryMarqueeSection.astro";
import FeatureSideImageSection from "@components/Feature/FeatureSideImageSection.astro";
import FeatureToggleImageSection from "@components/Feature/FeatureToggleImageSection.astro";
import ServicesIconSection from "@components/Services/ServicesIconSection.astro";
import ServicesSideImageSection from "@components/Services/ServicesSideImageSection.astro";
import RichTextBlock from "./RichTextBlock";

interface Block {
  discriminant: string;
  value: unknown;
}

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;
---

{
  blocks.map((block) => (
    <Fragment>
      {block.discriminant === "heroBg" && (block.value as { heroSet?: string | null })?.heroSet && (
        <HeroBgImageSection heroSet={(block.value as { heroSet: string }).heroSet} />
      )}
      {block.discriminant === "hero" && (block.value as { heroSet?: string | null })?.heroSet && (
        <HeroSideImageSection heroSet={(block.value as { heroSet: string }).heroSet} />
      )}
      {block.discriminant === "heroCentered" &&
        (block.value as { heroSet?: string | null })?.heroSet && (
          <HeroCenteredSection heroSet={(block.value as { heroSet: string }).heroSet} />
        )}
      {block.discriminant === "faq" && (block.value as { faqSet?: string | null })?.faqSet && (
        <FaqAccordionsSection faqSet={(block.value as { faqSet: string }).faqSet} />
      )}
      {block.discriminant === "faqCards" && (block.value as { faqSet?: string | null })?.faqSet && (
        <FaqCardsSection faqSet={(block.value as { faqSet: string }).faqSet} />
      )}
      {block.discriminant === "ctaBgImage" &&
        (block.value as { ctaSet?: string | null })?.ctaSet && (
          <CtaBgImageSection ctaSet={(block.value as { ctaSet: string }).ctaSet} />
        )}
      {block.discriminant === "ctaCardCenter" &&
        (block.value as { ctaSet?: string | null })?.ctaSet && (
          <CtaCardCenterSection ctaSet={(block.value as { ctaSet: string }).ctaSet} />
        )}
      {block.discriminant === "ctaCardCenter2" &&
        (block.value as { ctaSet?: string | null })?.ctaSet && (
          <CtaCardCenter2Section ctaSet={(block.value as { ctaSet: string }).ctaSet} />
        )}
      {block.discriminant === "ctaCards" && (block.value as { ctaSet?: string | null })?.ctaSet && (
        <CtaCardsSection ctaSet={(block.value as { ctaSet: string }).ctaSet} />
      )}
      {block.discriminant === "featureCardsSmall" &&
        (block.value as { featureSet?: string | null })?.featureSet && (
          <FeatureCardsSmallSection
            featureSet={(block.value as { featureSet: string }).featureSet}
          />
        )}
      {block.discriminant === "featureLightboxMarquee" &&
        (block.value as { featureSet?: string | null })?.featureSet && (
          <FeatureLightboxMarqueeSection
            featureSet={(block.value as { featureSet: string }).featureSet}
          />
        )}
      {block.discriminant === "featureGalleryMarquee" &&
        (block.value as { featureSet?: string | null })?.featureSet && (
          <FeatureGalleryMarqueeSection
            featureSet={(block.value as { featureSet: string }).featureSet}
          />
        )}
      {block.discriminant === "featureSideImage" &&
        (block.value as { featureSet?: string | null })?.featureSet && (
          <FeatureSideImageSection
            featureSet={(block.value as { featureSet: string }).featureSet}
          />
        )}
      {block.discriminant === "featureToggleImage" &&
        (block.value as { featureSet?: string | null })?.featureSet && (
          <FeatureToggleImageSection
            featureSet={(block.value as { featureSet: string }).featureSet}
          />
        )}
      {block.discriminant === "servicesIcon" &&
        (block.value as { servicesSet?: string | null })?.servicesSet && (
          <ServicesIconSection servicesSet={(block.value as { servicesSet: string }).servicesSet} />
        )}
      {block.discriminant === "servicesSideImage" &&
        (block.value as { servicesSet?: string | null })?.servicesSet && (
          <ServicesSideImageSection
            servicesSet={(block.value as { servicesSet: string }).servicesSet}
          />
        )}
      {block.discriminant === "richText" && block.value && (
        <div class="site-container my-16">
          <div class="markdown-content mx-auto max-w-3xl">
            <RichTextBlock
              document={block.value as Parameters<typeof RichTextBlock>[0]["document"]}
            />
          </div>
        </div>
      )}
    </Fragment>
  ))
}
