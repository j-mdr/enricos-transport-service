---
import type { HTMLAttributes } from "astro/types";
import { getLocaleFromUrl } from "@utils/localeUtils";

// These types represent RESOLVED GROQ data (reference->{ _type, slug }),
// NOT the schema-level unresolved reference types from sanity.types.ts.
// SanityLink works with query result shapes, not schema shapes.
export interface SanityExternalLink {
  _type: "externalLink";
  href?: string | null;
  openInNewTab?: boolean | null;
}

export interface SanityInternalLink {
  _type: "internalLink";
  reference?: {
    _type: string;
    slug?: { current?: string | null } | null;
  } | null;
}

export interface SanityLinkObject {
  text?: string | null;
  destination?: Array<SanityExternalLink | SanityInternalLink> | null;
}

interface Props extends HTMLAttributes<"a"> {
  link: SanityLinkObject;
  class?: string;
}

const { link, class: className, ...rest } = Astro.props;

const locale = getLocaleFromUrl(Astro.url);
const prefix = locale === "nl" ? "" : `/${locale}`;

const dest = link.destination?.[0];

function resolveHref(): string {
  if (!dest) return "/";
  if (dest._type === "internalLink") {
    const slug = dest.reference?.slug?.current ?? "";
    if (dest.reference?._type === "blogPost") return `${prefix}/blog/${slug}`;
    return `${prefix}/${slug}`;
  }
  return dest.href ?? "/";
}

const href = resolveHref();
const newTab = dest?._type === "externalLink" ? (dest.openInNewTab ?? false) : false;
---

<a
  href={href}
  class={className}
  target={newTab ? "_blank" : undefined}
  rel={newTab ? "noopener noreferrer" : undefined}
  {...rest}
>
  <slot>{link.text}</slot>
</a>
