---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import "swiper/css";
import "swiper/css/pagination";
import "./testimonialSwiper.css"; // have to define custom styles like this
import TestimonialCard from "./TestimonialCard.astro";
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import { testimonialsData } from "./testimonialsData";
import type { TestimonialSwiperSectionData } from "@config/configDataTypes.ts";

interface Props extends Partial<TestimonialSwiperSectionData> {
  testimonialsSet?: string;
}

const { title: propTitle, testimonials: propTestimonials, testimonialsSet } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);
const staticData = testimonialsData[currLocale];

// Load from collection when testimonialsSet is provided, fallback to static data
const entries = testimonialsSet !== undefined ? await getCollection("testimonials") : [];
const collectionEntry =
  testimonialsSet !== undefined
    ? (entries.find((e) => e.id === `${currLocale}/${testimonialsSet}`) ?? null)
    : null;

if (testimonialsSet !== undefined && !collectionEntry) return;

const title = collectionEntry ? collectionEntry.data.title : (propTitle ?? staticData.title);

const testimonials = collectionEntry
  ? collectionEntry.data.testimonials.map((t) => ({
      avatar: t.avatar ?? null,
      name: t.name,
      title: t.personTitle ?? "",
      testimonial: t.testimonial,
    }))
  : (propTestimonials ?? staticData.testimonials);

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="faq2" class="bg-base-200/50 py-20 md:my-16">
  <div class="site-container">
    <div class="flex justify-center">
      <h2 class="h2 text-center">
        {leadingText}
        {
          hasHighlightedWord && (
            <span>
              {highlightedWord}
              <Icon
                name="stellar/freehand-heart"
                class="text-primary-500 inline-block h-8"
                aria-hidden="true"
              />
            </span>
          )
        }
        {trailingText}
      </h2>
    </div>

    <div class="mt-10 overflow-hidden pb-10">
      <!-- swiper -->
      <div class="testimonials__swiper relative mt-10">
        <!-- Additional required wrapper -->
        <div class="swiper-wrapper">
          <!-- Slides -->
          {
            testimonials.map((testimonial, idx) => (
              <div class="swiper-slide">
                <TestimonialCard {...testimonial} />
              </div>
            ))
          }
        </div>
        <!-- If we need pagination -->
        <div class="swiper-pagination"></div>
      </div>
    </div>
  </div>
</section>

<script>
  // Import Swiper and modules
  import Swiper from "swiper";
  import type { SwiperOptions } from "swiper/types";
  import { Pagination } from "swiper/modules";
  // import { Navigation, Pagination, Scrollbar } from "swiper/modules";

  function swiperSetup() {
    const SwiperParams: SwiperOptions = {
      // Install modules
      modules: [Pagination],

      // Optional parameters
      direction: "horizontal",
      spaceBetween: 10,
      initialSlide: 1,
      grabCursor: true,
      centeredSlides: true,

      breakpoints: {
        // when window width is >= 768px
        768: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
        // when window width is >= 1024px
        1024: {
          slidesPerView: 3,
          spaceBetween: 40,
        },
      },

      // If we need pagination
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
    };

    // Now you can use Swiper
    const swiper = new Swiper(".testimonials__swiper", SwiperParams);
  }

  // runs on initial page load
  swiperSetup();

  // runs on view transitions navigation
  document.addEventListener("astro:after-swap", swiperSetup);
</script>
