---
/**
 * * Testimonials swiper carousel
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import { Icon } from "astro-icon/components";
import "swiper/css";
import "swiper/css/pagination";
import "./testimonialSwiper.css";
import TestimonialCard from "./TestimonialCard.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { SanityImageObject } from "@lib/sanityImage";

interface Props {
  title?: string;
  testimonials?: {
    name: string;
    personTitle?: string;
    testimonial: string;
    avatar?: SanityImageObject | null;
  }[];
  [key: string]: any;
}

const { title = "", testimonials = [] } = Astro.props;

if (!title || !testimonials.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="testimonials-swiper" class="bg-base-200/50 py-20 md:my-16">
  <div class="site-container">
    <div class="flex justify-center">
      <h2 class="h2 text-center">
        {leadingText}
        {
          hasHighlightedWord && (
            <span>
              {highlightedWord}
              <Icon
                name="stellar/freehand-heart"
                class="text-primary-500 inline-block h-8"
                aria-hidden="true"
              />
            </span>
          )
        }
        {trailingText}
      </h2>
    </div>

    <div class="mt-10 overflow-hidden pb-10">
      <div class="testimonials__swiper relative mt-10">
        <div class="swiper-wrapper">
          {
            testimonials.map((t) => (
              <div class="swiper-slide">
                <TestimonialCard
                  name={t.name}
                  title={t.personTitle}
                  testimonial={t.testimonial}
                  avatar={t.avatar}
                />
              </div>
            ))
          }
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import type { SwiperOptions } from "swiper/types";
  import { Pagination } from "swiper/modules";

  function swiperSetup() {
    const SwiperParams: SwiperOptions = {
      modules: [Pagination],
      direction: "horizontal",
      spaceBetween: 10,
      initialSlide: 1,
      grabCursor: true,
      centeredSlides: true,
      breakpoints: {
        768: { slidesPerView: 2, spaceBetween: 20 },
        1024: { slidesPerView: 3, spaceBetween: 40 },
      },
      pagination: { el: ".swiper-pagination", clickable: true },
    };
    new Swiper(".testimonials__swiper", SwiperParams);
  }

  swiperSetup();
  document.addEventListener("astro:after-swap", swiperSetup);
</script>
