---
/**
 * * Testimonials section columns (not swiper)
 */

import { Icon } from "astro-icon/components";

// components
import TestimonialCard from "./TestimonialCard.astro";

// utils
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { testimonialsData } from "./testimonialsData";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const testimonialData = testimonialsData[currLocale];
---

<section id="faq2" class="bg-base-200/50 py-20 md:my-16">
  <div class="site-container">
    <div class="flex justify-center">
      <h2 class="h2 text-center">
        {testimonialData.title}
      </h2>
    </div>
    <div class="mx-auto mt-20 grid gap-6 gap-y-20 sm:grid-cols-2 md:grid-cols-3">
      {testimonialData.testimonials.map((testimonial) => <TestimonialCard {...testimonial} />)}
    </div>
  </div>
</section>
