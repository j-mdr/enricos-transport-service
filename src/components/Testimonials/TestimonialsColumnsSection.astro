---
/**
 * * Testimonials section columns (not swiper)
 */

import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";

// components
import TestimonialCard from "./TestimonialCard.astro";

// utils
import { getLocaleFromUrl } from "@/utils/localeUtils";
import { testimonialsData } from "./testimonialsData";
import type { TestimonialSwiperSectionData } from "@config/configDataTypes.ts";

interface Props extends Partial<TestimonialSwiperSectionData> {
  testimonialsSet?: string;
}

const { title: propTitle, testimonials: propTestimonials, testimonialsSet } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);
const staticData = testimonialsData[currLocale];

// Load from collection when testimonialsSet is provided, fallback to static data
const entries = testimonialsSet !== undefined ? await getCollection("testimonials") : [];
const collectionEntry =
  testimonialsSet !== undefined
    ? (entries.find((e) => e.id === `${currLocale}/${testimonialsSet}`) ?? null)
    : null;

if (testimonialsSet !== undefined && !collectionEntry) return;

const title = collectionEntry ? collectionEntry.data.title : (propTitle ?? staticData.title);

const testimonials = collectionEntry
  ? collectionEntry.data.testimonials.map((t) => ({
      avatar: t.avatar ?? null,
      name: t.name,
      title: t.personTitle ?? "",
      testimonial: t.testimonial,
    }))
  : (propTestimonials ?? staticData.testimonials);
---

<section id="faq2" class="bg-base-200/50 py-20 md:my-16">
  <div class="site-container">
    <div class="flex justify-center">
      <h2 class="h2 text-center">
        {title}
      </h2>
    </div>
    <div class="mx-auto mt-20 grid gap-6 gap-y-20 sm:grid-cols-2 md:grid-cols-3">
      {testimonials.map((testimonial) => <TestimonialCard {...testimonial} />)}
    </div>
  </div>
</section>
