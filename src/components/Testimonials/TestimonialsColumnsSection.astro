---
/**
 * * Testimonials in columns layout
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import TestimonialCard from "./TestimonialCard.astro";
import type { SanityImageObject } from "@lib/sanityImage";

interface Props {
  title?: string;
  testimonials?: {
    name: string;
    personTitle?: string;
    testimonial: string;
    avatar?: SanityImageObject | null;
  }[];
  [key: string]: any;
}

const { title = "", testimonials = [] } = Astro.props;

if (!title || !testimonials.length) return;
---

<section id="testimonials-columns" class="bg-base-200/50 py-20 md:my-16">
  <div class="site-container">
    <div class="flex justify-center">
      <h2 class="h2 text-center">{title}</h2>
    </div>
    <div class="mx-auto mt-20 grid gap-6 gap-y-20 sm:grid-cols-2 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <TestimonialCard
            name={t.name}
            title={t.personTitle}
            testimonial={t.testimonial}
            avatar={t.avatar}
          />
        ))
      }
    </div>
  </div>
</section>
