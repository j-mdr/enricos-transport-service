---
/**
 * * Testimonials in columns layout
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import TestimonialCard from "./TestimonialCard.astro";
import { Icon } from "astro-icon/components";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "testimonialsColumns" }>;

const { title = "", testimonials = [] } = Astro.props;

if (!title || !testimonials.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section id="testimonials-columns" class="bg-base-200/50 py-16 md:py-24 lg:py-32">
  <div class="site-container">
    <div class="flex justify-center">
      <h2 class="h2 text-center">
        {leadingText}
        {
          hasHighlightedWord && (
            <span class="relative whitespace-nowrap">
              {highlightedWord}
              <span>
                <Icon
                  name="stellar/freehand-zig-underline"
                  class="text-primary-400 absolute top-1 left-0 -z-10 h-full w-full translate-y-1/2"
                  aria-hidden="true"
                />
              </span>
            </span>
          )
        }
        {trailingText ?? null}
      </h2>
    </div>
    <div class="mx-auto mt-10 grid gap-6 gap-y-20 sm:grid-cols-2 md:mt-12 md:grid-cols-3 lg:mt-16">
      {
        testimonials.map((t) => (
          <TestimonialCard
            name={t.name ?? ""}
            title={t.personTitle}
            testimonial={t.testimonial ?? ""}
            avatar={t.avatar}
          />
        ))
      }
    </div>
  </div>
</section>
