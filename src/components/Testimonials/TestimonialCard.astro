---
import { Icon } from "astro-icon/components";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import type { SanityImageObject } from "@lib/sanityImage";
import { getLocaleFromUrl } from "@utils/localeUtils";

const ui = {
  nl: { showMore: "Lees verder...", showLess: "Lees minder" },
  en: { showMore: "Read more...", showLess: "Read less" },
} as const;

interface Props {
  avatar?: SanityImageObject | null;
  name: string;
  title?: string;
  testimonial: string;
}

const { avatar, name, title, testimonial } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = ui[locale];

const id = `testimonial-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="flex">
  <div
    class="bg-base-50 flex flex-col items-center justify-between rounded-xl px-4 pb-8 text-center"
  >
    <div class="flex flex-col items-center">
      {
        avatar?.asset ? (
          <SanityImage
            image={avatar}
            width={160}
            height={160}
            sizesType="avatar"
            loading="lazy"
            class="border-primary-500 -mt-10 h-20 w-20 rounded-full border-2 object-cover"
          />
        ) : (
          <div class="border-primary-500 bg-base-200 -mt-10 flex h-20 w-20 items-center justify-center rounded-full border-2">
            <Icon name="tabler/user" class="h-10 w-10 opacity-60" aria-hidden="true" />
          </div>
        )
      }
      <p class="mt-4 text-lg">{name}</p>
      {title && <p class="opacity-80">{title}</p>}
      <div class="testimonial-wrapper mt-4">
        <input type="checkbox" id={id} class="testimonial-toggle" />
        <p class="testimonial-text">{testimonial}</p>
        <label
          for={id}
          class="testimonial-label text-primary-500 mt-1 cursor-pointer text-sm underline"
        >
          <span class="show-more">{t.showMore}</span>
          <span class="show-less">{t.showLess}</span>
        </label>
      </div>
    </div>
    <div class="mt-4 flex items-center justify-center gap-1">
      <Icon name="tabler/star-filled" class="h-6 w-6 text-yellow-500" aria-hidden="true" />
      <Icon name="tabler/star-filled" class="h-6 w-6 text-yellow-500" aria-hidden="true" />
      <Icon name="tabler/star-filled" class="h-6 w-6 text-yellow-500" aria-hidden="true" />
      <Icon name="tabler/star-filled" class="h-6 w-6 text-yellow-500" aria-hidden="true" />
      <Icon name="tabler/star-filled" class="h-6 w-6 text-yellow-500" aria-hidden="true" />
    </div>
  </div>
</div>

<style>
  /* Hide the actual checkbox */
  .testimonial-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  /* Clamp to 3 lines by default */
  .testimonial-text {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  /* Expand when checked */
  .testimonial-toggle:checked ~ .testimonial-text {
    -webkit-line-clamp: unset;
  }

  /* Toggle label text */
  .show-less {
    display: none;
  }

  .testimonial-toggle:checked ~ .testimonial-label .show-more {
    display: none;
  }

  .testimonial-toggle:checked ~ .testimonial-label .show-less {
    display: inline;
  }
</style>
