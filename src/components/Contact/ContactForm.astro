---
import { getLocaleFromUrl } from "@utils/localeUtils";
import ContactFormReact from "./ContactForm";
import { PUBLIC_TURNSTILE_SITE_KEY } from "astro:env/client";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type ContactBlock = Extract<Blocks[number], { _type: "contactSection"; form: unknown }>;

interface Props {
  form: ContactBlock["form"];
}

const { form } = Astro.props;
const turnstileSiteKey = PUBLIC_TURNSTILE_SITE_KEY ?? "";
const locale = getLocaleFromUrl(Astro.url);
---

<ContactFormReact form={form} turnstileSiteKey={turnstileSiteKey} locale={locale} client:visible />
