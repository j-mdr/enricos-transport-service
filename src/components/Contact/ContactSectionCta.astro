---
import ContactForm from "@components/Contact/ContactForm.astro";
import { Icon } from "astro-icon/components";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type ContactBlock = Extract<Blocks[number], { _type: "contactSection"; form: unknown }>;
type Props = Pick<ContactBlock, "title" | "form">;

const { title, form } = Astro.props;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } = splitTitleWithIcon(
  title ?? "",
);
---

<section id="contact-section" class="my-24 py-8 md:my-36">
  <div class="site-container">
    <div class="border-primary-300 relative h-full w-full overflow-hidden rounded-xl border">
      <!-- bottom left blob -->
      <Icon
        name="stellar/blob-1"
        class="text-primary-200/50 left- absolute top-1 -z-10 h-[200%] w-[150%] -translate-x-[50%] rotate-12"
        aria-hidden="true"
      />
      <!-- top left blob -->
      <Icon
        name="stellar/blob-2"
        class="text-primary-400/50 absolute top-1 left-0 -z-10 h-[200%] w-[150%] -translate-x-[50%] -translate-y-[50%] rotate-12"
        aria-hidden="true"
      />
      <!-- bottom right blob -->
      <Icon
        name="stellar/blob-2"
        class="text-primary-400/50 absolute top-0 left-0 -z-10 h-[200%] w-[150%] translate-x-[20%]"
        aria-hidden="true"
      />

      <div class="relative z-10 p-1">
        <div class="rounded-xl px-4 py-16 text-center">
          <div class="mx-auto max-w-2xl">
            {
              title && (
                <h2 class="h1 mb-10">
                  {leadingText}
                  {hasHighlightedWord && (
                    <span class="relative whitespace-nowrap">
                      {highlightedWord}
                      <span>
                        <Icon
                          name="stellar/freehand-zig-underline"
                          class="text-primary-400 absolute top-1 left-0 -z-10 h-full w-full translate-y-1/2"
                          aria-hidden="true"
                        />
                      </span>
                    </span>
                  )}
                  {trailingText ?? null}
                </h2>
              )
            }
            <ContactForm form={form} />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
