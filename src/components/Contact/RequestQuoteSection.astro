---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { getLocaleFromUrl } from "@utils/localeUtils";
import RequestQuote from "./RequestQuote.astro";

interface Props {
  sectionSet?: string;
}

const { sectionSet } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);

const entries = await getCollection("requestQuoteSection");
const entry = entries.find((e) => e.id === `${locale}/${sectionSet}`);

if (!entry) return;

const { title, image, imageAlt } = entry.data;
---

<section id="request-quote-section" class="my-12 overflow-hidden py-12">
  <div class="site-container">
    <div class="mx-auto flex max-w-2xl justify-center text-center">
      <h2 class="h2 text-center">{title}</h2>
    </div>

    <div class="mt-10 md:mt-16">
      <div class="mx-auto grid gap-8 rounded-xl md:grid-cols-2 md:gap-12 lg:gap-20">
        <!-- Linker kolom: offerteformulier -->
        <div class="col-span-1">
          <RequestQuote />
        </div>

        <!-- Rechter kolom: blob + afbeelding -->
        <div class="relative mx-auto max-w-4xl">
          <div class="absolute top-0 left-0 -z-10 h-full w-full">
            <Icon
              name="stellar/blob-0"
              class="text-primary-100 absolute top-0 left-0 h-auto w-[220%] -translate-x-1/4 -translate-y-[21%] md:-translate-x-1/3"
              aria-hidden="true"
            />
          </div>
          <Image
            class="relative rounded-xl border border-transparent object-cover"
            src={image}
            alt={imageAlt}
            height={700}
          />
        </div>
      </div>
    </div>
  </div>
</section>
