---
import ContactSectionCentered from "@components/Contact/ContactSectionCentered.astro";
import ContactSectionCta from "@components/Contact/ContactSectionCta.astro";
import ContactSectionWithImage from "@components/Contact/ContactSectionWithImage.astro";
import ContactSectionWithContactInfo from "@components/Contact/ContactSectionWithContactInfo.astro";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type ContactBlock = Extract<Blocks[number], { _type: "contactSection"; form: unknown }>;
type Props = ContactBlock;

const { type, title, image, form } = Astro.props;

const layout = type ?? "centered";
---

{layout === "centered" && <ContactSectionCentered title={title} form={form} />}
{layout === "withImage" && <ContactSectionWithImage title={title} form={form} image={image} />}
{layout === "withContactInfo" && <ContactSectionWithContactInfo form={form} />}
{layout === "withCta" && <ContactSectionCta title={title} form={form} />}
