---
import { Icon } from "astro-icon/components";
import SanityImage from "@components/SanityImage/SanityImage.astro";
import BecomePartnerForm from "./BecomePartnerForm.astro";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "becomePartnerSection" }>;

const { title, image } = Astro.props;

if (!title) return;
---

<section id="become-partner-section" class="my-4 overflow-hidden md:mt-16">
  <div class="site-container">
    <div class="mx-auto flex max-w-2xl justify-center text-center">
      <h2 class="h2 text-center">{title}</h2>
    </div>

    <div class="mt-10 md:mt-16">
      <div class="mx-auto grid gap-8 rounded-xl md:grid-cols-2 md:gap-12 lg:gap-20">
        <!-- Linker kolom: aanmeldformulier -->
        <div class="col-span-1">
          <BecomePartnerForm />
        </div>

        <!-- Rechter kolom: blob + afbeelding -->
        <div class="relative mx-auto hidden max-w-4xl md:block">
          <div class="absolute top-0 left-0 -z-10 h-full w-full">
            <Icon
              name="stellar/blob-0"
              class="text-primary-100 absolute top-0 left-0 h-auto w-[220%] -translate-x-1/4 -translate-y-[21%] md:-translate-x-1/3"
              aria-hidden="true"
            />
          </div>
          {
            image?.asset && (
              <SanityImage
                image={image}
                sizesType="half"
                loading="lazy"
                class="relative rounded-xl border border-transparent object-cover"
              />
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
