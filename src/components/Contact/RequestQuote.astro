---
import { getLocaleFromUrl } from "@utils/localeUtils";
import { getRequestQuoteLabels } from "@utils/requestQuote";
import RequestQuoteReact from "./RequestQuote";

const locale = getLocaleFromUrl(Astro.url);
const labels = await getRequestQuoteLabels(locale);

// Fallback labels indien singleton leeg is
const resolvedLabels = {
  formTitle: labels?.formTitle ?? (locale === "nl" ? "Offerte aanvragen" : "Request a Quote"),
  firstNameLabel: labels?.firstNameLabel ?? (locale === "nl" ? "Voornaam" : "First Name"),
  lastNameLabel: labels?.lastNameLabel ?? (locale === "nl" ? "Achternaam" : "Last Name"),
  emailLabel: labels?.emailLabel ?? (locale === "nl" ? "Emailadres" : "Email Address"),
  postalCodeFromLabel:
    labels?.postalCodeFromLabel ?? (locale === "nl" ? "Postcode van" : "Postal Code (from)"),
  postalCodeToLabel:
    labels?.postalCodeToLabel ?? (locale === "nl" ? "Postcode naar" : "Postal Code (to)"),
  cargoTypeLabel:
    labels?.cargoTypeLabel ??
    (locale === "nl" ? "Wat moet er vervoerd worden?" : "What needs to be transported?"),
  cargoOptions: labels?.cargoOptions?.length
    ? labels.cargoOptions
    : locale === "nl"
      ? [
          { value: "pakket-dozen", label: "Pakket / dozen" },
          { value: "pallets", label: "Pallets" },
          { value: "meubels", label: "Meubels" },
          { value: "documenten", label: "Documenten" },
        ]
      : [
          { value: "pakket-dozen", label: "Package / boxes" },
          { value: "pallets", label: "Pallets" },
          { value: "meubels", label: "Furniture" },
          { value: "documenten", label: "Documents" },
        ],
  cargoOptionAnders: labels?.cargoOptionAnders ?? (locale === "nl" ? "Anders" : "Other"),
  otherCargoLabel:
    labels?.otherCargoLabel ??
    (locale === "nl" ? "Omschrijf het te vervoeren goed" : "Describe the goods to be transported"),
  sizeWeightLabel:
    labels?.sizeWeightLabel ??
    (locale === "nl" ? "Geschatte grootte / gewicht" : "Estimated size / weight"),
  sizeOptions: labels?.sizeOptions?.length
    ? labels.sizeOptions
    : locale === "nl"
      ? [
          { value: "klein", label: "Klein (tot 25 kg)" },
          { value: "middel", label: "Middel (tot 100 kg)" },
          { value: "groot", label: "Groot (tot 500 kg)" },
          { value: "zwaar", label: "Zwaar (500+ kg)" },
          { value: "weet-niet", label: "Weet ik niet" },
        ]
      : [
          { value: "klein", label: "Small (up to 25 kg)" },
          { value: "middel", label: "Medium (up to 100 kg)" },
          { value: "groot", label: "Large (up to 500 kg)" },
          { value: "zwaar", label: "Heavy (500+ kg)" },
          { value: "weet-niet", label: "I don't know" },
        ],
  transportDateLabel:
    labels?.transportDateLabel ?? (locale === "nl" ? "Datum transport" : "Transport date"),
  urgentLabel: labels?.urgentLabel ?? (locale === "nl" ? "Spoedtransport" : "Express transport"),
  submitButtonText:
    labels?.submitButtonText ?? (locale === "nl" ? "Offerte aanvragen" : "Request Quote"),
  successMessage:
    labels?.successMessage ??
    (locale === "nl"
      ? "Bedankt! We nemen zo snel mogelijk contact met u op met een offerte."
      : "Thank you! We will get back to you as soon as possible with a quote."),
  errorMessage:
    labels?.errorMessage ??
    (locale === "nl"
      ? "Er is iets misgegaan. Probeer het later opnieuw."
      : "Something went wrong. Please try again later."),
};

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<RequestQuoteReact labels={resolvedLabels} turnstileSiteKey={turnstileSiteKey} client:load />
