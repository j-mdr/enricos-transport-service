---
/**
 * * Team member profile cards
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import Profile from "@components/Profile/Profile.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { GetPageBySlugQueryResult } from "../../../sanity.types";

type Blocks = NonNullable<NonNullable<GetPageBySlugQueryResult>["blocks"]>;
type Props = Extract<Blocks[number], { _type: "teamMemberCards" }>;

const { title = "" } = Astro.props;
const teamMembers = Astro.props.teamMembers ?? [];

if (!title || !teamMembers.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section class="site-container mt-20 md:mt-32">
  <h2 class="h2 text-center">
    {leadingText}
    {hasHighlightedWord && <span class="text-primary-600">{highlightedWord}</span>}
    {trailingText}
  </h2>
  <div class="mt-12 grid gap-8 sm:grid-cols-2 md:mt-16 lg:grid-cols-3">
    {
      teamMembers.map((member) => (
        <Profile
          name={member.name ?? ""}
          title={member.personTitle ?? undefined}
          image={member.avatar}
          bio={member.bio ?? undefined}
        />
      ))
    }
  </div>
</section>
