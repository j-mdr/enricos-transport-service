---
/**
 * * Team member profile cards
 * Data is passed as props from Sanity block builder via BlockRenderer
 */
import Profile from "@components/Profile/Profile.astro";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import type { SanityImageObject } from "@lib/sanityImage";

interface Props {
  title?: string;
  teamMembers?: {
    name: string;
    personTitle?: string;
    bio?: string;
    avatar?: SanityImageObject | null;
  }[];
  [key: string]: any;
}

const { title = "", teamMembers = [] } = Astro.props;

if (!title || !teamMembers.length) return;

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section class="site-container mt-24 md:mt-36">
  <h2 class="h2 text-center">
    {leadingText}
    {hasHighlightedWord && <span class="text-primary-600">{highlightedWord}</span>}
    {trailingText}
  </h2>
  <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {
      teamMembers.map((member) => (
        <Profile
          name={member.name}
          title={member.personTitle}
          image={member.avatar}
          bio={member.bio}
        />
      ))
    }
  </div>
</section>
