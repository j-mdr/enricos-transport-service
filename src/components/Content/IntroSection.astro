---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { splitTitleWithIcon } from "@utils/textUtils.ts";
import { getLocaleFromUrl } from "@/utils/localeUtils";

interface Props {
  title?: string;
  introText?: string;
  introSet?: string;
}

const { title: propTitle, introText: propIntroText, introSet } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);

// Load from collection when introSet is provided, fallback to props
const entries = introSet !== undefined ? await getCollection("introSection") : [];
const collectionEntry =
  introSet !== undefined
    ? (entries.find((e) => e.id === `${currLocale}/${introSet}`) ?? null)
    : null;

if (introSet !== undefined && !collectionEntry) return;

const title = collectionEntry ? collectionEntry.data.title : (propTitle ?? "");
const introText = collectionEntry ? collectionEntry.data.introText : (propIntroText ?? "");

const { leadingText, highlightedWord, trailingText, hasHighlightedWord } =
  splitTitleWithIcon(title);
---

<section class="site-container mx-auto pt-36 md:pt-44">
  <h1 class="h1 text-center">
    {leadingText}
    {
      hasHighlightedWord && (
        <span class="relative whitespace-nowrap">
          {highlightedWord}
          <span>
            <Icon
              name="stellar/freehand-zig-underline"
              class="text-primary-300 absolute top-2 left-0 -z-10 h-full w-full translate-y-[60%] scale-y-75"
              aria-hidden="true"
            />
          </span>
        </span>
      )
    }
    {trailingText}
  </h1>
  <p class="description mx-auto mt-10 max-w-2xl text-center md:mt-20">
    {introText}
  </p>
</section>
